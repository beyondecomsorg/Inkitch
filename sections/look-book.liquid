{% schema %}

{

  "name": "About Us - Fan Cards",

  "tag": "section",

  "class": "wau-section-wrapper",

  "settings": [

    {

      "type": "header",

      "content": "Content"

    },

    {

      "type": "textarea",

      "id": "heading",

      "label": "Heading",

      "default": "ABOUT US"

    },

    {

      "type": "textarea",

      "id": "body_text",

      "label": "Description",

      "default": "Welcome to inKitch, where we craft premium home and kitchen essentials that blend style, functionality, and durability to elevate your everyday living experience."

    },

    {

      "type": "text",

      "id": "cta_text",

      "label": "Button Text",

      "default": "OUR STORY"

    },

    {

      "type": "url",

      "id": "cta_url",

      "label": "Button Link"

    },



    {

      "type": "header",

      "content": "Typography"

    },

    {

      "type": "font_picker",

      "id": "section_font",

      "label": "Font Family",

      "default": "helvetica_n4"

    },

    {

      "type": "color",

      "id": "heading_color",

      "label": "Heading Color",

      "default": "#FFFFFF"

    },

    {

      "type": "range",

      "id": "heading_size",

      "label": "Heading Font Size",

      "min": 20,

      "max": 120,

      "step": 2,

      "unit": "px",

      "default": 40

    },

    {

      "type": "range",

      "id": "heading_size_mobile",

      "label": "Heading Font Size Mobile",

      "min": 16,

      "max": 80,

      "step": 1,

      "unit": "px",

      "default": 24

    },

    {

      "type": "range",

      "id": "heading_weight",

      "label": "Heading Font Weight",

      "min": 100,

      "max": 900,

      "step": 100,

      "default": 700

    },

    {

      "type": "color",

      "id": "body_color",

      "label": "Body Text Color",

      "default": "#FFFFFF"

    },

    {

      "type": "range",

      "id": "body_size",

      "label": "Body Font Size",

      "min": 12,

      "max": 40,

      "step": 1,

      "unit": "px",

      "default": 14

    },

    {

      "type": "range",

      "id": "body_size_mobile",

      "label": "Body Font Size Mobile",

      "min": 12,

      "max": 30,

      "step": 1,

      "unit": "px",

      "default": 14

    },

    {

      "type": "range",

      "id": "body_weight",

      "label": "Body Font Weight",

      "min": 100,

      "max": 900,

      "step": 100,

      "default": 400

    },



    {

