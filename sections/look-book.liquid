{% comment %}

  ============================================================

  ABOUT US — Polaroid Fan Layout  |

  ============================================================

{% endcomment %}



{%- liquid

  assign bg_color = section.settings.background_color

  assign heading   = section.settings.heading

  assign body_text = section.settings.body_text

  assign cta_text  = section.settings.cta_text

  assign cta_url   = section.settings.cta_url

  assign accent    = section.settings.accent_color

  assign card_blocks = section.blocks | where: 'type', 'card'

-%}



<section
  class="wau-section section-wrapper"
  id="wau-{{ section.id }}"
  style="
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --section-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --section-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
  "
>

  <!-- BG image layer -->

  {%- if section.settings.bg_image != blank -%}

    <div class="wau-bg-img" style="background-image: url('{{ section.settings.bg_image | image_url: width: 1600 }}');"></div>

  {%- endif -%}

  <div class="wau-bg-overlay"></div>



  <div class="wau-inner">



    <!-- ═══ LEFT ═══ -->

<div class="wau-left">

  {% if section.settings.heading != blank %}

    <h2 class="wau-heading">

      {{ section.settings.heading }}

    </h2>

  {% endif %}



  {% if section.settings.body_text != blank %}

    <div class="wau-body ccc">

      {{ section.settings.body_text }}

    </div>

  {% endif %}



  {% if section.settings.cta_text != blank %}

    <a href="{{ section.settings.cta_url }}" class="wau-cta">

      <span>{{ section.settings.cta_text }}</span>



      <svg width="18" height="18" viewBox="0 0 14 14" fill="none">

        <path

          d="M1 7H13M13 7L7 1M13 7L7 13"

          stroke="currentColor"

          stroke-width="1.5"

          stroke-linecap="round"

          stroke-linejoin="round"

        />

      </svg>

    </a>

  {% endif %}



  <div class="wau-stats">

    {% for block in section.blocks %}

      {% if block.type == 'stat' %}

        <div class="wau-stat-pill" {{ block.shopify_attributes }}>

          <strong>{{ block.settings.stat_value }}</strong>

          <span>{{ block.settings.stat_label }}</span>

        </div>

      {% endif %}

    {% endfor %}

  </div>

</div>



    <!-- ═══ RIGHT — Polaroid Fan ═══ -->

<div class="wau-right">

  <div class="wau-fan-wrap">



    {% for block in section.blocks %}

      {% if block.type == 'card' %}

        <div class="wau-pcard wau-pcard--{{ forloop.index0 }}" {{ block.shopify_attributes }}>



          <div class="wau-pcard__inner">



            {% if block.settings.card_image != blank %}

              {{

                block.settings.card_image

                | image_url: width: 700

                | image_tag:

                  loading: 'lazy',

                  class: 'wau-pcard__img'

              }}

            {% endif %}



            {% if block.settings.card_label != blank %}

              <div class="wau-pcard__caption">

                {{ block.settings.card_label }}

              </div>

            {% endif %}



          </div>



        </div>

      {% endif %}

    {% endfor %}



    <div class="wau-blob wau-blob--1"></div>

    <div class="wau-blob wau-blob--2"></div>



  </div>

</div>

  </div><!-- /inner -->



  <!-- ═══ MARQUEE STRIP ═══ -->





</section>




<style>
#wau-{{ section.id }} *, #wau-{{ section.id }} *::before, #wau-{{ section.id }} *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

#wau-{{ section.id }} {
  --wau-bg: linear-gradient(135deg, #8b0000 0%, #c0000f 40%, #E30613 100%) !important;
  --wau-accent: var(--color-copper-rivet, #B87333);
  --wau-blob-color: var(--color-raw-denim-blue, #345E8A);

  --wau-heading-color: var(--color-off-white, #FFFFFF);
  --wau-body-color: var(--color-off-white, #FFFFFF);

  --wau-button-bg: var(--color-off-white, #FFFFFF);
  --wau-button-text: var(--color-deep-navy, #0B1F33);
  --wau-button-hover-bg: var(--color-off-white, #FFFFFF);
  --wau-button-hover-text: var(--color-deep-navy, #0B1F33);

  --wau-stats-number-color: var(--color-copper-rivet, #ffffffff);
  --wau-stats-label-color: var(--color-off-white, #FFFFFF);
  --wau-stats-number-size: 28px;
  --wau-stats-number-weight: 700;
  --wau-stats-label-size: 11px;
  --wau-stats-label-weight: 600;

  --wau-heading-size: clamp(36px, 4.5vw, 56px);
  --wau-heading-weight: 700;

  --wau-body-size: 16px;
  --wau-body-weight: 400;

  --wau-button-size: 14px;
  --wau-button-weight: 700;

  --wau-pt: var(--section-padding-top);
  --wau-pb: var(--section-padding-bottom);
}

@media (max-width: 1024px) {
  #wau-{{ section.id }} {
    --wau-pt: var(--section-padding-top-mobile);
    --wau-pb: var(--section-padding-bottom-mobile);
    --wau-body-size: 14px;
  }
}

.shopify-section.wau-section-wrapper{
  margin-top: 60px
}

/* --- Shell --- */
#wau-{{ section.id }}.wau-section,
.wau-section-wrapper .wau-section {
  position: relative !important;
  width: 100vw !important;
  left: 50% !important;
  margin-left: -50vw !important;
  margin-right: -50vw !important;
  min-height: 500px !important;
  padding-top: var(--wau-pt) !important;
  padding-bottom: calc(var(--wau-pb) + 0px) !important; /* Increased bottom buffer to contain rotated elements */
  background: var(--wau-bg) !important;
  display: block !important;
  opacity: 1 !important;
  visibility: visible !important;
  overflow: visible !important; /* Keep visible within bounds to prevent ugly clipping */
  box-sizing: border-box !important;
}

@media (max-width: 1024px) {
    .shopify-section.wau-section-wrapper{
  margin-top: 0px
}
  #wau-{{ section.id }}.wau-section,
  .wau-section-wrapper .wau-section {
    min-height: auto !important;
    overflow: visible !important; /* Keep fanned elements visible on mobile */
    padding-bottom: calc(var(--wau-pb) + 70px) !important; /* Mobile bottom buffer */
  }
}

/* Background image overlay control */
#wau-{{ section.id }} .wau-bg-img {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
  z-index: 0;
}

#wau-{{ section.id }} .wau-bg-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(100deg, rgba(11,31,51,0.92) 0%, rgba(11,31,51,0.70) 55%, rgba(11,31,51,0.30) 100%);
  z-index: 1;
  display: none !important;
}

#wau-{{ section.id }} .wau-bg-img + .wau-bg-overlay {
  display: block !important;
}

/* --- Inner grid --- */
#wau-{{ section.id }} .wau-inner {
  position: relative;
  z-index: 2;
  max-width: var(--global-max-container-width-desktop, 1400px) !important;
  margin: 0 auto !important;
  padding: 0 var(--global-container-side-padding-desktop, 40px) 0 !important;
  display: grid !important;
  grid-template-columns: 1fr 1fr !important;
  gap: 80px !important; /* Increased gap between text column and image stack */
  align-items: center !important;
  justify-content: center !important;
  min-height: 500px !important;
  width: 100% !important;
  box-sizing: border-box !important;
}

@media (max-width: 1024px) {
  #wau-{{ section.id }} .wau-inner {
    grid-template-columns: 1fr !important;
    padding: 0 var(--global-container-side-padding-mobile, 20px) 0 !important;
    gap: 40px !important;
    min-height: auto !important;
  }
}

/* --- LEFT Column --- */
#wau-{{ section.id }} .wau-left {
  display: flex !important;
  flex-direction: column !important;
  align-items: flex-start !important;
  justify-content: center !important;
  padding-right: 0 !important; /* Let grid gap handle spacing */
  width: 100% !important;
  margin: 0 !important;
  box-sizing: border-box !important;
}

@media (max-width: 1024px) {
  #wau-{{ section.id }} .wau-left {
    align-items: center !important;
    text-align: center !important;
  }
}

#wau-{{ section.id }} .wau-heading {
  font-family: var(--font-heading-family) !important;
  font-size: 32px !important;
  font-weight: 700 !important;
  color: #fff !important;
  margin: 0 0 10px 0 !important;
  position: relative !important;
  display: inline-block !important;
}

#wau-{{ section.id }} .wau-body {
  font-family: var(--font-body-family), "Inter", sans-serif !important;
  font-size: 14px !important;
  color: #fff !important;
  margin: 0 !important;
  line-height: 1.6 !important;
  max-width: 480px !important;
}

@media (max-width: 1024px) {
  #wau-{{ section.id }} .wau-body {
    margin-left: auto !important;
    margin-right: auto !important;
  }
}

#wau-{{ section.id }} .wau-cta {
  display: inline-flex !important;
  align-items: center !important;
  justify-content: center !important;
  gap: 8px !important;
  text-decoration: none !important;
  font-family: var(--font-body-family), "Inter", sans-serif !important;
  font-weight: var(--wau-button-weight) !important;
  background: var(--wau-button-bg) !important;
  color: var(--wau-button-text) !important;
  padding: 12px 28px !important;
  margin-top: 24px !important; /* Add spacing below the marginless body text */
  border: none !important;
  border-radius: 10px !important;
  height: auto !important;
  min-height: auto !important;
  width: auto !important;
  min-width: auto !important;
  letter-spacing: 0.08em !important;
  text-transform: uppercase !important;
  transition: opacity 0.3s ease, background-color 0.3s ease, color 0.3s ease !important;
  box-sizing: border-box !important;
}

#wau-{{ section.id }} .wau-cta:hover {
  background: var(--wau-button-hover-bg) !important;
  color: var(--wau-button-hover-text) !important;
  opacity: 0.9 !important;
}

#wau-{{ section.id }} .wau-cta svg {
  stroke: var(--wau-button-text) !important;
  transition: transform 0.3s ease !important;
}

#wau-{{ section.id }} .wau-cta:hover svg {
  transform: translateX(4px) !important;
}

#wau-{{ section.id }} .wau-cta::after {
  display: none !important;
}

/* Stats */
#wau-{{ section.id }} .wau-stats {
  display: flex !important;
  flex-direction: row !important;
  flex-wrap: nowrap !important;
  gap: 20px !important; /* Increased consistent gaps */
  margin-top: 48px !important; /* More top margin spacing */
  width: 100% !important;
}

#wau-{{ section.id }} .wau-stat-pill {
  flex: 1 1 0% !important;
  background: rgba(11, 31, 51, 0.45) !important;
  border: 1px solid rgba(255, 255, 255, 0.15) !important;
  padding: 24px 20px !important; /* Increased padding inside stat box */
  display: flex !important;
  flex-direction: column !important;
  gap: 8px !important;
  align-items: flex-start !important;
  border-radius: 0 !important;
  box-sizing: border-box !important;
  text-align: left !important;
  backdrop-filter: blur(10px);
  transition: background-color 0.25s, border-color 0.25s !important;
}

#wau-{{ section.id }} .wau-stat-pill:hover {
  background: rgba(11, 31, 51, 0.55) !important;
  border-color: rgba(255, 255, 255, 0.3) !important;
}

#wau-{{ section.id }} .wau-stat-pill strong {
  font-family: var(--font-heading-family), "Canela", "Freight Display", serif !important;
  font-size: var(--wau-stats-number-size) !important;
  font-weight: 300 !important;
  color: var(--wau-stats-number-color) !important;
  line-height: 1.1 !important;
}

#wau-{{ section.id }} .wau-stat-pill span {
  font-family: var(--font-body-family), "Inter", sans-serif !important;
  font-size: var(--wau-stats-label-size) !important;
  font-weight: var(--wau-stats-label-weight) !important;
  letter-spacing: 0.05em !important;
  text-transform: uppercase !important;
  color: var(--wau-stats-label-color) !important;
  line-height: 1.3 !important;
}

@media (max-width: 1024px) {
  #wau-{{ section.id }} .wau-stats {
    flex-wrap: wrap !important;
    justify-content: center !important;
    gap: 16px !important;
  }

  #wau-{{ section.id }} .wau-stat-pill {
    flex: 1 1 calc(33.33% - 12px) !important;
    align-items: center !important;
    text-align: center !important;
    padding: 16px 12px !important;
  }
}

@media (max-width: 480px) {
  #wau-{{ section.id }} .wau-stat-pill {
    flex: 1 1 100% !important;
  }
}

/* --- RIGHT Column (Polaroid Fan Cards) --- */
#wau-{{ section.id }} .wau-right {
  display: flex !important;
  justify-content: center !important;
  align-items: center !important;
  width: 100% !important;
  position: relative !important;
}

#wau-{{ section.id }} .wau-fan-wrap {
  position: relative !important;
  width: 100% !important;
  max-width: 480px !important;
  height: 560px !important; /* Increased height to naturally bound elements */
  margin: 0 auto !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  z-index: 2 !important;
}

#wau-{{ section.id }} .wau-pcard {
  position: absolute !important;
  width: 240px !important;
  background: var(--color-off-white, #FFFFFF) !important;
  padding: 12px 12px 24px !important;
  box-shadow: 0 20px 40px rgba(11, 31, 51, 0.25) !important;
  border: 1px solid rgba(0, 0, 0, 0.05) !important;
  border-radius: 0 !important;
  transform-origin: center bottom !important;
  transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), box-shadow 0.4s ease !important;
  z-index: 10 !important;
