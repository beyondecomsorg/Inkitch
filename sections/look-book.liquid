  top: 60px !important;
  --base-rot: -12deg;
  transform: rotate(-12deg);
}

#wau-{{ section.id }} .wau-pcard--1 {
  left: 120px !important;
  top: 20px !important;
  z-index: 11 !important;
  --base-rot: 2deg;
  transform: rotate(2deg);
}

#wau-{{ section.id }} .wau-pcard--2 {
  left: 220px !important;
  top: 70px !important;
  z-index: 12 !important;
  --base-rot: 14deg;
  transform: rotate(14deg);
}

#wau-{{ section.id }} .wau-pcard__inner {
  width: 100% !important;
  overflow: hidden !important;
  display: flex !important;
  flex-direction: column !important;
}

#wau-{{ section.id }} .wau-pcard__img {
  width: 100% !important;
  height: auto !important;
  aspect-ratio: 3/4 !important;
  object-fit: cover !important;
  display: block !important;
  border-radius: 0 !important;
  transition: transform 0.5s ease !important;
}

#wau-{{ section.id }} .wau-pcard:hover .wau-pcard__img {
  transform: scale(1.04) !important;
}

#wau-{{ section.id }} .wau-pcard__caption {
  text-align: center !important;
  margin-top: 14px !important;
  font-family: var(--font-body-family), "Inter", sans-serif !important;
  font-size: 11px !important;
  font-weight: 700 !important;
  letter-spacing: 0.08em !important;
  text-transform: uppercase !important;
  color: var(--color-deep-navy, #0B1F33) !important;
}

@media (max-width: 1024px) {
  #wau-{{ section.id }} .wau-fan-wrap {
    height: 400px !important; /* Balanced container height on mobile */
    max-width: 360px !important;
  }

  #wau-{{ section.id }} .wau-pcard {
    width: 170px !important;
    padding: 8px 8px 18px !important;
  }

  #wau-{{ section.id }} .wau-pcard--0 {
    left: 10px !important;
    top: 40px !important;
  }

  #wau-{{ section.id }} .wau-pcard--1 {
    left: 95px !important;
    top: 15px !important;
  }

  #wau-{{ section.id }} .wau-pcard--2 {
    left: 180px !important;
    top: 50px !important;
  }
}

@media (max-width: 480px) {
  #wau-{{ section.id }} .wau-fan-wrap {
    height: 300px !important; /* Balanced container height on small screen mobile */
    max-width: 280px !important;
  }

  #wau-{{ section.id }} .wau-pcard {
    width: 130px !important;
    padding: 6px 6px 14px !important;
  }

  #wau-{{ section.id }} .wau-pcard--0 {
    left: 5px !important;
    top: 30px !important;
  }

  #wau-{{ section.id }} .wau-pcard--1 {
    left: 75px !important;
    top: 10px !important;
  }

  #wau-{{ section.id }} .wau-pcard--2 {
    left: 145px !important;
    top: 40px !important;
  }
}

/* Blobs */
#wau-{{ section.id }} .wau-blob {
  position: absolute !important;
  filter: blur(70px) !important;
  pointer-events: none !important;
  z-index: 1 !important;
}

#wau-{{ section.id }} .wau-blob--1 {
  width: 280px !important;
  height: 280px !important;
  background: var(--wau-accent) !important;
  opacity: 0.07 !important;
  top: -20px !important;
  right: -40px !important;
  animation: wau-pulse 7s ease-in-out infinite alternate !important;
}

#wau-{{ section.id }} .wau-blob--2 {
  width: 220px !important;
  height: 220px !important;
  background: var(--wau-blob-color) !important;
  opacity: 0.1 !important;
  bottom: 30px !important;
  left: 10px !important;
  animation: wau-pulse 9s ease-in-out infinite alternate-reverse !important;
}

@keyframes wau-pulse {
  from { transform: scale(1); }
  to { transform: scale(1.3); }
}
</style>




<!-- ════════════════════════════

  JAVASCRIPT

════════════════════════════ -->

<script>

(function () {

  const SEC = document.getElementById('wau-{{ section.id }}');

  if (!SEC) return;



  /* 1 — Scroll reveal */

  const io = new IntersectionObserver(([e]) => {

    if (e.isIntersecting) { SEC.classList.add('wau-visible'); io.disconnect(); }

  }, { threshold: 0.12 });

  io.observe(SEC);



  /* 2 — Gentle 3D Y-axis rotate per card, staggered phase */

  const cards = SEC.querySelectorAll('.wau-pcard');

  const DUR = 7.0; // seconds per full cycle

  const MAX_Y = 16; // degrees

  const MAX_X = 5;



  // Read the base static rotation from CSS var

  const baseRots = [-12, 2, 14];



  cards.forEach((card, i) => {

    const phaseOffset = (i / cards.length) * DUR; // stagger 1/3 cycle each

    let startTs = null;

    let isHovered = false;



    card.addEventListener('mouseenter', () => { isHovered = true; });

    card.addEventListener('mouseleave', () => { isHovered = false; });



    function tick(ts) {

      if (!startTs) startTs = ts;

      const elapsed = ((ts - startTs) / 1000) + phaseOffset;

      const angle = (elapsed / DUR) * Math.PI * 2;



      if (!isHovered) {

        const rotY = Math.sin(angle) * MAX_Y;

        const rotX = Math.cos(angle) * MAX_X;

        const baseZ = baseRots[i] || 0;

        card.style.transform = `rotate(${baseZ}deg) perspective(800px) rotateY(${rotY}deg) rotateX(${rotX}deg)`;

      } else {

        // On hover: straighten and lift

        card.style.transform = `rotate(0deg) perspective(800px) rotateY(0deg) rotateX(0deg) translateY(-8px) scale(1.05)`;

      }

      requestAnimationFrame(tick);

    }

    requestAnimationFrame(tick);

  });



  /* 3 — Duplicate ticker for seamless loop */

  const track = document.getElementById('wau-ticker-{{ section.id }}');

  if (track) {

    while (track.scrollWidth < window.innerWidth * 4) {

      track.innerHTML += track.innerHTML;

    }

  }

})();

</script>



