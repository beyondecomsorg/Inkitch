{% comment %}
  Product Comparison Table Section
{% endcomment %}

{% if product.metafields.custom.product_table_features != blank %}
  {{ 'component-product-comparison.css' | asset_url | stylesheet_tag }}

  {% assign brand_name = product.metafields.custom.comparison_brand_name | default: section.settings.brand_name | default: "Brand" %}
  {% assign other_brand_name = product.metafields.custom.comparison_other_brand_name | default: section.settings.other_brand_name | default: "Others" %}

  <div class="product-comparison-section page-width section-{{ section.id }}-padding">
    <div class="product-comparison-header">
      {% if section.settings.eyebrow != blank %}
        <p class="product-comparison-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="product-comparison-heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="product-comparison-subheading">{{ section.settings.subheading | escape }}</p>
      {% endif %}
    </div>

    <div class="product-comparison-table">
      <!-- Table Header -->
      <div class="product-comparison-row product-comparison-row--header">
        <div class="product-comparison-cell product-comparison-cell--feature-header">Feature</div>
        <div class="product-comparison-cell product-comparison-cell--brand-header">{{ brand_name | escape }}</div>
        <div class="product-comparison-cell product-comparison-cell--other-header">{{ other_brand_name | escape }}</div>
      </div>

      <!-- Table Body -->
      {% assign features = product.metafields.custom.product_table_features.value %}
      {% assign brand_values = product.metafields.custom.product_table_brand_values.value %}
      {% assign other_values = product.metafields.custom.product_table_other_brand_values.value %}

      {% for feature in features %}
        {% assign i = forloop.index0 %}
        {% assign brand_val = brand_values[i] %}
        {% assign other_val = other_values[i] %}

        {% if feature != blank and brand_val != blank and other_val != blank %}
          <div class="product-comparison-row">
            <div class="product-comparison-cell product-comparison-cell--feature">{{ feature | escape }}</div>
            <div class="product-comparison-cell product-comparison-cell--brand">
              <svg class="product-comparison-icon product-comparison-icon--check" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M5 13l4 4L19 7" stroke="#2b872f" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="product-comparison-val">{{ brand_val | escape }}</span>
            </div>
            <div class="product-comparison-cell product-comparison-cell--other">
              <svg class="product-comparison-icon product-comparison-icon--cross" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M18 6L6 18M6 6l12 12" stroke="#d24343" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="product-comparison-val">{{ other_val | escape }}</span>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Product Comparison Table",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "THE COMPARISON"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Text",
      "default": "Mesmerize vs. everything else."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading Text",
      "default": "Most stone bracelets look similar at first. What separates them is what you can't see, until something breaks."
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Default Brand Name",
      "default": "Brand"
    },
    {
      "type": "text",
      "id": "other_brand_name",
      "label": "Default Other Brand Name",
      "default": "Others"
    }
  ],
  "presets": [
    {
      "name": "Product Comparison Table"
    }
  ]
}
{% endschema %}
