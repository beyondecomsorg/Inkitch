{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .footer-wrapper-custom-glow {
    background: linear-gradient(180deg, #1a1a1a 0%, #111111 100%) !important;
    border-top: 4px solid #E30613 !important;
    box-shadow: 0 -4px 30px rgba(227,6,19,0.15) inset !important;
    padding: 60px 40px 30px 40px !important;
    position: relative !important;
    box-sizing: border-box !important;
  }

  .footer-wrapper-custom-glow a {
    transition: color 0.2s ease, text-decoration 0.2s ease !important;
    text-decoration: none !important;
  }

  .footer-wrapper-custom-glow a:hover {
    text-decoration: underline !important;
  }

  .footer__blocks-wrapper-custom {
    display: grid !important;
    grid-template-columns: 2fr 1fr 1fr 1fr !important;
    gap: 40px !important;
    width: 100% !important;
    box-sizing: border-box !important;
  }

  .footer-block-heading-custom {
    font-size: var(--font-size-h3) !important;
    font-weight: var(--font-weight-heading) !important;
    color: #ffffff !important;
    text-transform: uppercase !important;
    letter-spacing: 1px !important;
    margin: 0 !important;
    line-height: 1.2 !important;
  }

  .footer-block-accent-line-custom {
    width: 30px !important;
    height: 2px !important;
    background-color: #E30613 !important;
    margin: 8px 0 16px 0 !important;
  }

  /* Quick Links Column */
  .footer-links-list-custom {
    list-style: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  .footer-links-list-custom li {
    margin-bottom: 4px !important;
  }

  .footer-link-custom {
    font-size: var(--font-size-small) !important;
    color: #aaaaaa !important;
    display: block !important;
    padding: 5px 0 !important;
    text-decoration: none !important;
    transition: all 0.2s ease !important;
  }

  .footer-link-arrow-custom {
    color: #E30613 !important;
    margin-right: 6px !important;
    display: inline-block !important;
  }

  .footer-link-custom:hover {
    color: #ffffff !important;
    padding-left: 4px !important;
  }

  /* Brand Column Overrides */
  .footer-block__brand-info h2,
  .footer-block__brand-info .footer-block__heading {
    font-size: var(--font-size-h2) !important;
    font-weight: var(--font-weight-heading) !important;
    color: #ffffff !important;
    margin: 0 !important;
    text-transform: none !important;
  }

  .footer-block__brand-info h2::after,
  .footer-block__brand-info .footer-block__heading::after {
    content: '' !important;
    display: block !important;
    width: 40px !important;
    height: 3px !important;
    background: #E30613 !important;
    margin: 8px 0 14px 0 !important;
  }

  .footer-block__brand-info .rte,
  .footer-block__brand-info div {
    font-size: var(--font-size-body) !important;
    color: #aaaaaa !important;
    line-height: 1.8 !important;
    max-width: 260px !important;
    margin-bottom: 20px !important;
  }

  .footer-block__brand-info .footer__list-social,
  .footer-block__brand-info .list-social {
    display: flex !important;
    gap: 10px !important;
    list-style: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  .footer-block__brand-info .list-social__item {
    margin: 0 !important;
  }

  .footer-block__brand-info .list-social__link {
    width: 36px !important;
    height: 36px !important;
    border-radius: 50% !important;
    background: rgba(255,255,255,0.08) !important;
    border: 1px solid rgba(255,255,255,0.12) !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    transition: all 0.3s ease !important;
    color: #ffffff !important;
    padding: 0 !important;
  }

  .footer-block__brand-info .list-social__link:hover {
    background: #E30613 !important;
    border-color: #E30613 !important;
    color: #ffffff !important;
  }

  .footer-block__brand-info .list-social__link svg {
    width: 16px !important;
    height: 16px !important;
    fill: currentColor !important;
  }

  /* Contact Us Column */
  .footer-contact-details-custom {
    display: flex !important;
    flex-direction: column !important;
    gap: 12px !important;
  }

  .footer-contact-item-custom {
    display: flex !important;
    align-items: flex-start !important;
    gap: 10px !important;
    transition: color 0.2s ease !important;
    text-decoration: none !important;
  }

  .footer-contact-icon-custom {
    font-size: var(--font-size-small) !important;
    flex-shrink: 0 !important;
  }

  .footer-contact-text-custom {
    font-size: var(--font-size-small) !important;
    color: #aaaaaa !important;
    line-height: 1.6 !important;
    transition: color 0.2s ease !important;
  }

  .footer-contact-value-custom {
    color: #ffffff !important;
    font-weight: 500 !important;
    transition: color 0.2s ease !important;
  }

  .footer-contact-item-custom:hover .footer-contact-text-custom,
  .footer-contact-item-custom:hover .footer-contact-value-custom {
    color: #E30613 !important;
  }

  /* Heading style for blocks */
  .footer-block h2.footer-block__heading {
    font-size: var(--font-size-h3) !important;
    font-weight: var(--font-weight-heading) !important;
    color: #ffffff !important;
    text-transform: uppercase !important;
    letter-spacing: 1px !important;
    margin: 0 !important;
    line-height: 1.2 !important;
  }

  .footer-block h2.footer-block__heading::after {
    content: '' !important;
    display: block !important;
    width: 30px !important;
    height: 2px !important;
    background-color: #E30613 !important;
    margin: 8px 0 16px 0 !important;
  }

  /* Newsletter Column */
  .footer-newsletter-subtitle-custom {
    font-size: var(--font-size-small) !important;
    color: #aaaaaa !important;
    margin-bottom: 16px !important;
    line-height: 1.6 !important;
  }

  .footer-newsletter-field-custom {
    display: flex !important;
    flex-direction: column !important;
    width: 100% !important;
  }

  .footer-newsletter-input-custom {
    width: 100% !important;
    padding: 11px 14px !important;
    background: rgba(255,255,255,0.07) !important;
    border: 1px solid rgba(255,255,255,0.15) !important;
    border-radius: 8px !important;
    color: #ffffff !important;
    font-size: var(--font-size-small) !important;
    box-sizing: border-box !important;
    transition: border-color 0.2s ease !important;
  }

  .footer-newsletter-input-custom::placeholder {
    color: #666666 !important;
  }

  .footer-newsletter-input-custom:focus {
    border-color: #E30613 !important;
    outline: none !important;
  }

  .footer-newsletter-button-custom {
    width: 100% !important;
    padding: 11px !important;
    background: #E30613 !important;
    color: #ffffff !important;
    border-radius: 8px !important;
    font-weight: 700 !important;
    font-size: var(--font-size-small) !important;
    border: none !important;
    cursor: pointer !important;
    margin-top: 8px !important;
    transition: background 0.3s ease !important;
    text-align: center !important;
  }

  .footer-newsletter-button-custom:hover {
    background: #c0000f !important;
  }

  /* Hide default newsletter wrapper */
  .footer-block--newsletter {
    display: none !important;
  }

  .footer__content-bottom {
    display: none !important;
  }

  /* Bottom Bar custom styling */
  .footer-divider-custom {
    border: none !important;
    border-top: 1px solid rgba(255,255,255,0.08) !important;
    margin: 30px 0 20px 0 !important;
    display: block !important;
    width: 100% !important;
  }

  .footer-bottom-bar-custom {
    display: flex !important;
    justify-content: space-between !important;
    align-items: center !important;
    padding: 10px 0 20px 0 !important;
    box-sizing: border-box !important;
  }

  .footer-bottom-left-custom,
  .footer-bottom-right-custom {
    font-size: var(--font-size-small) !important;
    color: #666666 !important;
  }

  .footer-bottom-center-custom .list-payment {
    display: flex !important;
    gap: 8px !important;
    padding: 0 !important;
    margin: 0 !important;
    list-style: none !important;
  }

  .footer-bottom-center-custom .list-payment__item {
    background: #ffffff !important;
    border-radius: 4px !important;
    padding: 3px 6px !important;
    height: 22px !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    box-sizing: content-box !important;
  }

  .footer-bottom-center-custom .list-payment__item svg {
    height: 22px !important;
    width: auto !important;
    max-height: 22px !important;
  }

  @media screen and (max-width: 990px) {
    .footer__blocks-wrapper-custom {
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 30px !important;
    }
  }

  @media screen and (max-width: 768px) {
    .footer-wrapper-custom-glow {
      padding: 40px 20px 20px 20px !important;
    }

    .footer__blocks-wrapper-custom {
      grid-template-columns: 1fr !important;
      gap: 0 !important;
    }

    .footer-column-custom {
      margin-top: 28px !important;
      width: 100% !important;
    }

    .footer-column-custom:first-child {
      margin-top: 0 !important;
    }

    .footer-block__brand-info .list-social {
      justify-content: center !important;
    }

    .footer-bottom-bar-custom {
      flex-direction: column !important;
      text-align: center !important;
      gap: 12px !important;
    }
  }
{%- endstyle -%}

<footer class="footer footer-wrapper-custom-glow color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  {%- liquid
    assign has_social_icons = true
    if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank
      assign has_social_icons = false
    endif

    if settings.brand_image == blank and settings.brand_headline == blank and settings.brand_description == blank
      assign brand_empty = true
    endif

    if section.blocks.size == 1 and section.blocks[0].type == 'brand_information' and brand_empty and has_social_icons == false and section.settings.newsletter_enable == false and section.settings.enable_follow_on_shop == false
      assign only_empty_brand = true
    endif
  -%}
  {%- if section.blocks.size > 0
    or section.settings.newsletter_enable
    or section.settings.show_social
    and has_social_icons == true
    or section.settings.enable_follow_on_shop
  -%}
    {%- unless only_empty_brand -%}
      <div class="footer__content-top page-width">
        {%- if section.blocks.size > 0 -%}
          <div
            class="footer__blocks-wrapper-custom {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
            {% endif %}
          >
            {%- for block in section.blocks -%}
              <div
                class="footer-block footer-column-custom {% if block.type == 'brand_information' %}footer-block__brand-info-wrapper{% endif %}"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.heading != blank -%}
                  <h2 class="footer-block__heading inline-richtext">{{- block.settings.heading -}}</h2>
                {%- endif -%}

                {%- case block.type -%}
                  {%- when '@app' -%}
                    {% render block %}
                  {%- when 'text' -%}
                    {%- if block.settings.heading contains 'Contact' or block.settings.heading contains 'contact' -%}
                      <div class="footer-block__details-content footer-contact-details-custom">
                        {%- assign contact_text_clean = block.settings.subtext | replace: '</p>', '' | replace: '<p>', '' | replace: '<br />', '|' | replace: '<br>', '|' -%}
                        {%- assign lines = contact_text_clean | split: '|' -%}
                        {%- for line in lines -%}
                          {%- assign line_trimmed = line | strip -%}
                          {%- if line_trimmed != blank -%}
                            {%- liquid
                              assign icon = "📞"
                              if line_trimmed contains "WhatsApp"
                                assign icon = "💬"
                              elsif line_trimmed contains "Support"
                                assign icon = "🕐"
                              elsif line_trimmed contains "Email"
                                assign icon = "✉"
                              endif
                              
                              assign parts = line_trimmed | split: ':'
                              assign label = parts[0] | strip
                              assign val = parts[1] | strip
                            -%}
                            <div class="footer-contact-item-custom">
                              <span class="footer-contact-icon-custom">{{ icon }}</span>
                              <span class="footer-contact-text-custom">
                                {{ label }}: <span class="footer-contact-value-custom">{{ val }}</span>
                              </span>
                            </div>
                          {%- endif -%}
                        {%- endfor -%}
                      </div>
                    {%- else -%}
                      <div class="footer-block__details-content rte">
                        {{ block.settings.subtext }}
                      </div>
                    {%- endif -%}
                  {%- when 'link_list' -%}
                    {%- if block.settings.menu != blank -%}
                      <ul class="footer-block__details-content list-unstyled">
                        {%- for link in block.settings.menu.links -%}
                          <li>
                            <a
                              href="{{ link.url }}"
                              class="link link--text list-menu__item list-menu__item--link{% if link.active %} list-menu__item--active{% endif %}"
                            >
                              {{ link.title | escape }}
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                  {%- when 'brand_information' -%}
                    <div class="footer-block__brand-info">
                      {%- if settings.brand_image != blank -%}
                        {%- assign brand_image_height = settings.brand_image_width
                          | divided_by: settings.brand_image.aspect_ratio
                        -%}
                        <div
                          class="footer-block__image-wrapper"
                          style="max-width: min(100%, {{ settings.brand_image_width }}px);"
                        >
                          {{
                            settings.brand_image
                            | image_url: width: 1100
                            | image_tag:
                              loading: 'lazy',
                              widths: '50, 100, 150, 200, 300, 400, 550, 800, 1100',
                              height: brand_image_height,
                              width: settings.brand_image_width
                          }}
                        </div>
                      {%- endif -%}
                      {%- if settings.brand_headline != blank -%}
                        <h2 class="footer-block__heading rte">{{ settings.brand_headline }}</h2>
                      {%- endif -%}
                      {%- if settings.brand_description != blank -%}
                        <div class="rte">{{ settings.brand_description }}</div>
                      {%- endif -%}
                      {%- if block.settings.show_social and has_social_icons -%}
                        {%- render 'social-icons', class: 'footer__list-social' -%}
                      {%- endif -%}
                    </div>
                  {%- when 'image' -%}
                    <div class="footer-block__details-content footer-block-image {{ block.settings.alignment }}">
                      {%- if block.settings.image != blank -%}
                        {%- assign image_size_2x = block.settings.image_width | times: 2 | at_most: 5760 -%}
                        <div
                          class="footer-block__image-wrapper"
                          style="max-width: min(100%, {{ block.settings.image_width }}px);"
                        >
                          <img
                            srcset="{{ block.settings.image | image_url: width: block.settings.image_width }}, {{ block.settings.image | image_url: width: image_size_2x }} 2x"
                            src="{{ block.settings.image | image_url: width: 760 }}"
                            alt="{{ block.settings.image.alt | escape }}"
                            loading="lazy"
                            width="{{ block.settings.image.width }}"
                            height="{{ block.settings.image.height }}"
                          >
                        </div>
                      {%- else -%}
                        {{ 'image' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
                      {%- endif -%}
                    </div>
                {%- endcase -%}
              </div>

              {%- if block.type == 'brand_information' or forloop.first -%}
                <!-- Column 2 — Quick Links (Custom) -->
                <div class="footer-block footer-column-custom quick-links-column-custom">
                  <h2 class="footer-block-heading-custom">Quick Links</h2>
                  <div class="footer-block-accent-line-custom"></div>
                  <ul class="footer-links-list-custom">
                    {%- assign quick_links = linklists.main-menu.links -%}
                    {%- if quick_links.size > 0 -%}
                      {%- for link in quick_links -%}
                        <li>
                          <a href="{{ link.url }}" class="footer-link-custom">
                            <span class="footer-link-arrow-custom">&rarr;</span>{{ link.title | escape }}
                          </a>
                        </li>
                      {%- endfor -%}
                    {%- else -%}
                      <li><a href="{{ routes.root_url }}" class="footer-link-custom"><span class="footer-link-arrow-custom">&rarr;</span>Home</a></li>
                      <li><a href="{{ routes.all_products_collection_url }}" class="footer-link-custom"><span class="footer-link-arrow-custom">&rarr;</span>Shop</a></li>
                      <li><a href="/pages/about-us" class="footer-link-custom"><span class="footer-link-arrow-custom">&rarr;</span>About Us</a></li>
                      <li><a href="/blogs/news" class="footer-link-custom"><span class="footer-link-arrow-custom">&rarr;</span>Blog</a></li>
                      <li><a href="/pages/contact" class="footer-link-custom"><span class="footer-link-arrow-custom">&rarr;</span>Contact</a></li>
                    {%- endif -%}
                  </ul>
                </div>
              {%- endif -%}
            {%- endfor -%}

            <!-- Column 4 — Newsletter (Custom) -->
            <div class="footer-block footer-column-custom newsletter-column-custom">
              <h2 class="footer-block-heading-custom">Stay Updated</h2>
              <div class="footer-block-accent-line-custom"></div>
              <p class="footer-newsletter-subtitle-custom">Get exclusive deals & kitchen tips in your inbox</p>
              {%- form 'customer', id: 'ContactFooterCustom', class: 'footer__newsletter-custom' -%}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <div class="footer-newsletter-field-custom">
                  <input
                    id="NewsletterFormCustom"
                    type="email"
                    name="contact[email]"
                    class="footer-newsletter-input-custom"
                    value="{{ form.email }}"
                    placeholder="Enter your email"
                    required
                  >
                  <button type="submit" class="footer-newsletter-button-custom">
                    Subscribe &rarr;
                  </button>
                </div>
              {%- endform -%}
            </div>
          </div>
        {%- endif -%}
      </div>
    {%- endunless -%}
  {%- endif -%}

  <!-- Bottom Bar & Divider Custom -->
  <div class="footer-divider-custom"></div>
  <div class="footer-bottom-bar-custom page-width">
    <div class="footer-bottom-left-custom">
      &copy; {{ 'now' | date: '%Y' }} inKitch. All rights reserved.
    </div>
    
    {%- if section.settings.payment_enable -%}
      <div class="footer-bottom-center-custom">
        <ul class="list list-payment" role="list">
          {%- for type in shop.enabled_payment_types -%}
            <li class="list-payment__item">
              {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    <div class="footer-bottom-right-custom">
      Made with ❤️ in India
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "t:sections.footer.blocks.link_list.settings.heading.default",
          "label": "t:sections.footer.blocks.link_list.settings.heading.label"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "t:sections.footer.blocks.link_list.settings.menu.label"
        }
      ]
    },
    {
      "type": "brand_information",
      "name": "t:sections.footer.blocks.brand_information.name",
      "settings": [
        {
          "type": "paragraph",
          "content": "t:sections.footer.blocks.brand_information.settings.paragraph.content"
        },
        {
          "type": "checkbox",
          "id": "show_social",
          "default": true,
          "label": "t:sections.footer.blocks.brand_information.settings.show_social.label",
          "info": "t:sections.footer.blocks.brand_information.settings.show_social.info"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.footer.blocks.text.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "t:sections.footer.blocks.text.settings.heading.default",
          "label": "t:sections.footer.blocks.text.settings.heading.label"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "default": "t:sections.footer.blocks.text.settings.subtext.default",
          "label": "t:sections.footer.blocks.text.settings.subtext.label"
        }
      ]
    },
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "range",
          "id": "image_width",
          "min": 50,
          "max": 550,
          "step": 5,
          "unit": "px",
          "label": "Width",
          "default": 100
        },
        {
          "type": "select",
          "id": "alignment",
          "label": "Alignment",
          "options": [
            {
              "value": "",
              "label": "Left"
            },
            {
              "value": "center",
              "label": "Center"
            },
            {
              "value": "right",
              "label": "Right"
            }
          ],
          "default": "center"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__1.content",
      "info": "t:sections.footer.settings.header__1.info"
    },
    {
      "type": "checkbox",
      "id": "newsletter_enable",
      "default": true,
      "label": "t:sections.footer.settings.newsletter_enable.label"
    },
    {
      "type": "inline_richtext",
      "id": "newsletter_heading",
      "default": "t:sections.footer.settings.newsletter_heading.default",
      "label": "t:sections.footer.settings.newsletter_heading.label"
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__9.content"
    },
    {
      "type": "checkbox",
      "id": "enable_follow_on_shop",
      "default": true,
      "label": "t:sections.footer.settings.enable_follow_on_shop.label",
      "info": "t:sections.footer.settings.enable_follow_on_shop.info"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "default": true,
      "label": "t:sections.footer.settings.show_social.label",
      "info": "t:sections.footer.settings.show_social.info"
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
