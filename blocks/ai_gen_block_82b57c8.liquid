{% doc %}
  @prompt
    Create a custom section called "New & Popular". At the top, display a bold centered heading that says "New & Popular". Below the heading, show 3 tab links in a row centered on the page: "New Arrivals", "Best Sellers", and "Barista Picks". The active tab should have a dark underline beneath it and slightly bolder text. Clicking a tab switches the product grid below it.
    Each tab displays a horizontal row of 5 product cards. Each card has a thin light gray border, no border radius, and a white background. The product image fills most of the card. In the top-right corner of each card, show a small dark green circular "+" quick-add button. If a product is sold out, show a dark gray "SOLD OUT" badge in the bottom-left corner of the card.
    The "New Arrivals" tab should pull products from a collection I can select in the theme editor. The "Best Sellers" tab should pull from a second collection I can select. The "Barista Picks" tab should pull from a third collection I can select.
    All three tab label names should be editable from the theme editor. The number of products shown per tab should be configurable (default 5). On mobile, the product row should scroll horizontally so all cards stay in a single row.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-new-popular-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: #fafafa;
    padding: 70px 24px;
    border-top: 4px solid #E30613;
  }

  .ai-new-popular-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-new-popular-heading-wrapper-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 30px;
  }

  .ai-new-popular-heading-{{ ai_gen_id }} {
    font-size: 32px;
    font-weight: 700;
    color: #111;
    margin: 0 0 10px 0;
    position: relative;
    display: inline-block;
    font-family: var(--font-heading), serif;
  }

  .ai-new-popular-heading-{{ ai_gen_id }}::after {
    content: '';
    display: block;
    width: 60px;
    height: 3px;
    background-color: #E30613;
    margin: 8px auto 0;
    border-radius: 2px;
  }

  .ai-new-popular-subtitle-{{ ai_gen_id }} {
    font-size: 14px;
    color: #888;
    margin: 0;
    font-family: var(--font-body), sans-serif;
  }

  .ai-new-popular-tabs-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 32px;
    margin-bottom: 40px;
    border-bottom: 1px solid #eee;
  }

  .ai-new-popular-tab-{{ ai_gen_id }} {
    background: transparent;
    color: #888;
    font-weight: 500;
    font-size: 15px;
    padding: 10px 0;
    border: none;
    border-bottom: 3px solid transparent;
    cursor: pointer;
    transition: all 0.3s ease;
    outline: none;
  }

  .ai-new-popular-tab-{{ ai_gen_id }}:hover {
    color: #E30613;
  }

  .ai-new-popular-tab-{{ ai_gen_id }}.active {
    color: #E30613;
    border-bottom: 3px solid #E30613;
    font-weight: 700;
  }

  .ai-new-popular-content-{{ ai_gen_id }} {
    display: none;
  }

  .ai-new-popular-content-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-new-popular-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 20px;
    width: 100%;
  }

  .ai-new-popular-card-{{ ai_gen_id }} {
    background-color: #ffffff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0,0,0,0.07);
    transition: all 0.3s ease;
    position: relative;
    border: 1px solid #f0f0f0;
    display: flex;
    flex-direction: column;
  }

  .ai-new-popular-card-{{ ai_gen_id }}:hover {
    transform: translateY(-6px);
    border-color: #E30613;
    box-shadow: 0 8px 30px rgba(227,6,19,0.12);
  }

  .ai-new-popular-card-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 230px;
    background-color: #f8f8f8;
    padding: 16px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px 12px 0 0;
  }

  .ai-new-popular-card-image-{{ ai_gen_id }} {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    transition: transform 0.35s ease;
  }

  .ai-new-popular-card-{{ ai_gen_id }}:hover .ai-new-popular-card-image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-new-popular-card-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-new-popular-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-new-popular-quick-add-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background-color: #E30613;
    color: #ffffff;
    border: none;
    cursor: pointer;
    font-weight: 600;
    font-size: 13px;
    text-align: center;
    padding: 10px 0;
    transform: translateY(100%);
    transition: transform 0.3s ease;
    z-index: 3;
    display: block;
    width: 100%;
  }

  .ai-new-popular-card-{{ ai_gen_id }}:hover .ai-new-popular-quick-add-{{ ai_gen_id }} {
    transform: translateY(0);
  }

  .ai-new-popular-sold-out-badge-{{ ai_gen_id }} {
    position: absolute;
    bottom: 10px;
    left: 10px;
    background-color: #4a4a4a;
    color: #ffffff;
    padding: 4px 8px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.5px;
    z-index: 3;
    border-radius: 4px;
  }

  .ai-new-popular-badge-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    left: 12px;
    border-radius: 20px;
    padding: 4px 10px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.8px;
    z-index: 3;
    color: #ffffff;
    text-transform: uppercase;
  }

  .ai-new-popular-badge-{{ ai_gen_id }}.badge-new {
    background-color: #E30613;
    box-shadow: 0 2px 8px rgba(227,6,19,0.35);
  }

  .ai-new-popular-badge-{{ ai_gen_id }}.badge-top {
    background-color: #E30613;
    box-shadow: 0 2px 8px rgba(227,6,19,0.35);
  }

  .ai-new-popular-badge-{{ ai_gen_id }}.badge-barista {
    background-color: #C9A84C;
    box-shadow: 0 2px 8px rgba(201,168,76,0.35);
  }

  .ai-new-popular-card-info-{{ ai_gen_id }} {
    padding: 16px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .ai-new-popular-card-title-{{ ai_gen_id }} {
    font-size: 13px;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 8px;
    text-decoration: none;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.4;
    min-height: 2.8em;
  }

  .ai-new-popular-card-title-{{ ai_gen_id }}:hover {
    color: #E30613;
    text-decoration: none;
  }

  .ai-new-popular-card-price-{{ ai_gen_id }} {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    font-weight: 700;
    color: #E30613;
    flex-wrap: wrap;
  }

  .ai-new-popular-compare-price-{{ ai_gen_id }} {
    font-size: 12px;
    color: #aaa;
    text-decoration: line-through;
    font-weight: 400;
  }

  .ai-new-popular-sale-price-{{ ai_gen_id }} {
    color: #E30613;
    font-weight: 700;
  }

  .ai-new-popular-regular-price-{{ ai_gen_id }} {
    color: #222;
    font-weight: 600;
  }

  .ai-new-popular-savings-badge-{{ ai_gen_id }} {
    background-color: #e8f5e9;
    color: #2e7d32;
    border-radius: 12px;
    padding: 2px 8px;
    font-size: 11px;
    font-weight: 600;
    display: inline-block;
  }

  .ai-new-popular-cta-wrapper-{{ ai_gen_id }} {
    text-align: center;
    margin-top: 40px;
  }

  .ai-new-popular-cta-btn-{{ ai_gen_id }} {
    display: inline-block;
    border: 2px solid #E30613;
    color: #E30613;
    background-color: #ffffff;
    border-radius: 10px;
    padding: 14px 40px;
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .ai-new-popular-cta-btn-{{ ai_gen_id }}:hover {
    background-color: #E30613;
    color: #ffffff;
  }

  .ai-new-popular-cta-btn-{{ ai_gen_id }} span {
    display: inline-block;
    transition: transform 0.3s ease;
  }

  .ai-new-popular-cta-btn-{{ ai_gen_id }}:hover span {
    transform: translateX(4px);
  }

  .ai-new-popular-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #999;
    font-style: italic;
  }

  @media screen and (max-width: 989px) {
    .ai-new-popular-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-new-popular-tabs-{{ ai_gen_id }} {
      gap: 20px;
      margin-bottom: 24px;
      overflow-x: auto;
      white-space: nowrap;
      justify-content: flex-start;
      padding: 0 24px;
      margin-left: -24px;
      margin-right: -24px;
      scrollbar-width: none;
    }
    
    .ai-new-popular-tabs-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-new-popular-tab-{{ ai_gen_id }} {
      padding: 8px 12px;
      flex-shrink: 0;
    }

    .ai-new-popular-grid-{{ ai_gen_id }} {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      gap: 16px;
      padding: 10px 24px 20px;
      margin: 0 -24px;
    }

    .ai-new-popular-grid-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none;
    }

    .ai-new-popular-card-{{ ai_gen_id }} {
      flex: 0 0 65%;
      min-width: 220px;
      scroll-snap-align: start;
    }

    .ai-new-popular-card-image-wrapper-{{ ai_gen_id }} {
      height: 180px;
      padding: 12px;
    }

    .ai-new-popular-quick-add-{{ ai_gen_id }} {
      transform: translateY(0);
      font-size: 12px;
      padding: 8px 0;
    }
  }
{% endstyle %}

<new-popular-tabs-{{ ai_gen_id }} class="ai-new-popular-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-new-popular-container-{{ ai_gen_id }}">
    
    <div class="ai-new-popular-heading-wrapper-{{ ai_gen_id }}">
      <h2 class="ai-new-popular-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      <p class="ai-new-popular-subtitle-{{ ai_gen_id }}">Handpicked products loved by our customers</p>
    </div>

    <div class="ai-new-popular-tabs-{{ ai_gen_id }}">
      <button
        class="ai-new-popular-tab-{{ ai_gen_id }} active"
        data-tab="new-arrivals"
        aria-selected="true"
        role="tab"
      >
        {{ block.settings.tab_1_label }}
      </button>
      <button
        class="ai-new-popular-tab-{{ ai_gen_id }}"
        data-tab="best-sellers"
        aria-selected="false"
        role="tab"
      >
        {{ block.settings.tab_2_label }}
      </button>
      <button
        class="ai-new-popular-tab-{{ ai_gen_id }}"
        data-tab="barista-picks"
        aria-selected="false"
        role="tab"
      >
        {{ block.settings.tab_3_label }}
      </button>
    </div>

    <div
      class="ai-new-popular-content-{{ ai_gen_id }} active"
      data-content="new-arrivals"
      role="tabpanel"
    >
      {% if block.settings.collection_1 != blank %}
        <div class="ai-new-popular-grid-{{ ai_gen_id }}">
          {% for product in block.settings.collection_1.products limit: block.settings.products_per_tab %}
            <div class="ai-new-popular-card-{{ ai_gen_id }}">
              <div class="ai-new-popular-card-image-wrapper-{{ ai_gen_id }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 400 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    class="ai-new-popular-card-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="400"
                    height="500"
                  >
                {% else %}
                  <div class="ai-new-popular-card-image-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}

                {% if product.available %}
                <a href="{{ product.url }}">

                  <button
                    class="ai-new-popular-quick-add-{{ ai_gen_id }}"
                    data-product-id="{{ product.id }}"
                    aria-label="Quick add {{ product.title }}"
                  >
              Shop Now
                  </button>
                  </a>
                {% else %}
                  <div class="ai-new-popular-sold-out-badge-{{ ai_gen_id }}">SOLD OUT</div>
                {% endif %}
                <span class="ai-new-popular-badge-{{ ai_gen_id }} badge-new">NEW</span>
              </div>

              <div class="ai-new-popular-card-info-{{ ai_gen_id }}">
                <a
                  href="{{ product.url }}"
                  class="ai-new-popular-card-title-{{ ai_gen_id }}"
                >
                  {{ product.title }}
                </a>
                <div class="ai-new-popular-card-price-{{ ai_gen_id }}">
                  {% if product.compare_at_price > product.price %}
                    <span class="ai-new-popular-compare-price-{{ ai_gen_id }}">
                      {{ product.compare_at_price | money | remove: ".00" }}
                    </span>
                    <span class="ai-new-popular-sale-price-{{ ai_gen_id }}">
                      {{ product.price | money | remove: ".00" }}
                    </span>
                    {% liquid
                      assign savings_amt = product.compare_at_price | minus: product.price
                      assign savings_percent = savings_amt | times: 100 | divided_by: product.compare_at_price
                    %}
                    <span class="ai-new-popular-savings-badge-{{ ai_gen_id }}">{{ savings_percent }}% off</span>
                  {% else %}
                    <span class="ai-new-popular-regular-price-{{ ai_gen_id }}">
                      {{ product.price | money | remove: ".00" }}
                    </span>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <div class="ai-new-popular-empty-{{ ai_gen_id }}">
          Select a collection for {{ block.settings.tab_1_label }} in the theme editor
        </div>
      {% endif %}
    </div>

    <div
