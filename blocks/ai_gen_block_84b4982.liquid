{% doc %}
  @prompt
    100% SECURE PAYMENTS
    Moving your card details to a much more secured place
    TRUSTPAY
    100% Payment Protection. Easy Return Policy
    HELP CENTER
    Got a question? Look no further. Browse our FAQs or submit your query here.
    SHOP ON THE GO
    Download the app and get exciting app only offers at your fingertips
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-trust-badges-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-trust-badges-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap }}px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-trust-badge-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.alignment }};
    text-align: {{ block.settings.alignment }};
    gap: {{ block.settings.icon_text_gap }}px;
  }

  .ai-trust-badge-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    color: {{ block.settings.icon_color }};
  }

  .ai-trust-badge-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-trust-badge-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ai-trust-badge-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-trust-badge-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-trust-badges-container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-trust-badge-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size_mobile }}px;
      height: {{ block.settings.icon_size_mobile }}px;
    }

    .ai-trust-badge-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
    }

    .ai-trust-badge-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-trust-badges-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-trust-badges-container-{{ ai_gen_id }}">
    <div class="ai-trust-badge-{{ ai_gen_id }}">
      <div class="ai-trust-badge-icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
          <line x1="1" y1="10" x2="23" y2="10"></line>
        </svg>
      </div>
      <div class="ai-trust-badge-content-{{ ai_gen_id }}">
        <h3 class="ai-trust-badge-title-{{ ai_gen_id }}">{{ block.settings.badge_1_title }}</h3>
        <p class="ai-trust-badge-description-{{ ai_gen_id }}">{{ block.settings.badge_1_description }}</p>
      </div>
    </div>

    <div class="ai-trust-badge-{{ ai_gen_id }}">
      <div class="ai-trust-badge-icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
          <path d="M9 12l2 2 4-4"></path>
        </svg>
      </div>
      <div class="ai-trust-badge-content-{{ ai_gen_id }}">
        <h3 class="ai-trust-badge-title-{{ ai_gen_id }}">{{ block.settings.badge_2_title }}</h3>
        <p class="ai-trust-badge-description-{{ ai_gen_id }}">{{ block.settings.badge_2_description }}</p>
      </div>
    </div>

    <div class="ai-trust-badge-{{ ai_gen_id }}">
      <div class="ai-trust-badge-icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
          <line x1="12" y1="17" x2="12.01" y2="17"></line>
        </svg>
      </div>
      <div class="ai-trust-badge-content-{{ ai_gen_id }}">
        <h3 class="ai-trust-badge-title-{{ ai_gen_id }}">{{ block.settings.badge_3_title }}</h3>
        <p class="ai-trust-badge-description-{{ ai_gen_id }}">{{ block.settings.badge_3_description }}</p>
      </div>
    </div>

    <div class="ai-trust-badge-{{ ai_gen_id }}">
      <div class="ai-trust-badge-icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
          <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
        </svg>
      </div>
      <div class="ai-trust-badge-content-{{ ai_gen_id }}">
        <h3 class="ai-trust-badge-title-{{ ai_gen_id }}">{{ block.settings.badge_4_title }}</h3>
        <p class="ai-trust-badge-description-{{ ai_gen_id }}">{{ block.settings.badge_4_description }}</p>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Trust badges",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
