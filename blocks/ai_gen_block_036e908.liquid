{% doc %}
  @prompt
    “Create a premium mobile-first testimonial section design in vertical slide format (1080x1920 Instagram Story/PPT slide style) for a kitchenware/lifestyle brand. Use a rich teal background with elegant minimal aesthetics.
    
    At the top center, add a clean white heading:
    ‘Verified, Honest Reviews’
    
    Below it, place a large rounded-corner testimonial card in soft pastel blue/light cyan with subtle shadows and generous spacing.
    
    Inside the card include:
    
    * 5 elegant star icons at the top
    * Large bold review title: ‘Superb Finish’
    * Short customer review text in modern clean typography
    * Circular customer profile image centered below review text
    * Customer name in bold at the bottom
    
    Design style should be:
    
    * Premium and minimal
    * Luxury cookware/homeware brand aesthetic
    * Soft rounded corners
    * Modern sans-serif fonts like Poppins or Montserrat
    * Clean alignment and lots of white space
    * Mobile responsive slide composition
    * Presentation-style layout suitable for Canva, PowerPoint, Instagram Story, or website slides
    
    Use smooth spacing, subtle shadows, and a polished UI/UX feel.”
    , Add slides in the same for more reviews
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonial-slider-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: linear-gradient(135deg, #8b0000 0%, #c0000f 40%, #E30613 100%) !important;
    padding: 70px 24px !important;
    position: relative !important;
    overflow: hidden !important;
    box-sizing: border-box;
  }

  /* Subtle diagonal texture */
  .ai-testimonial-slider-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background-image: repeating-linear-gradient(
      45deg, rgba(255,255,255,0.03) 0px,
      rgba(255,255,255,0.03) 1px, transparent 1px, transparent 12px
    ) !important;
    pointer-events: none;
    z-index: 1;
  }

  /* Decorative circles */
  .ai-testimonial-circle-1-{{ ai_gen_id }} {
    position: absolute;
    top: -80px;
    left: -80px;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: rgba(255,255,255,0.04);
    pointer-events: none;
    z-index: 1;
  }

  .ai-testimonial-circle-2-{{ ai_gen_id }} {
    position: absolute;
    bottom: -60px;
    right: -60px;
    width: 250px;
    height: 250px;
    border-radius: 50%;
    background: rgba(255,255,255,0.04);
    pointer-events: none;
    z-index: 1;
  }

  .ai-testimonial-header-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    text-align: center;
    margin-bottom: 50px;
  }

  .ai-testimonial-slider__heading-{{ ai_gen_id }} {
    font-size: 34px !important;
    font-weight: 800 !important;
    color: #ffffff !important;
    text-align: center !important;
    margin: 0 !important;
    text-shadow: 0 2px 8px rgba(0,0,0,0.2) !important;
    line-height: 1.2;
    font-family: inherit;
  }

  .ai-testimonial-heading-accent-{{ ai_gen_id }} {
    width: 60px;
    height: 3px;
    background-color: #ffffff;
    opacity: 0.6;
    margin: 10px auto 0;
  }

  .ai-testimonial-subtitle-{{ ai_gen_id }} {
    color: rgba(255,255,255,0.75);
    font-size: 14px;
    margin-top: 10px;
    margin-bottom: 0;
    text-align: center;
  }

  .ai-testimonial-slider__slides-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: 460px;
    z-index: 2;
  }

  /* Slide transition - pure CSS animation based on DOM order */
  .ai-testimonial-slider__slide-{{ ai_gen_id }} {
    position: absolute;
    width: 100%;
    left: 0;
    top: 0;
    opacity: 0;
    visibility: hidden;
    transform: translateX(-30px);
    transition: opacity 0.4s ease, transform 0.4s ease, visibility 0.4s ease !important;
  }

  .ai-testimonial-slider__slide-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
    transform: translateX(0) !important;
  }

  .ai-testimonial-slider__slide-{{ ai_gen_id }}.active ~ .ai-testimonial-slider__slide-{{ ai_gen_id }} {
    transform: translateX(30px);
  }

  .ai-testimonial-slider__card-{{ ai_gen_id }} {
    background: #ffffff !important;
    border-radius: 20px !important;
    padding: 36px 32px !important;
    box-shadow: 0 20px 60px rgba(0,0,0,0.2) !important;
    max-width: 600px !important;
    margin: 0 auto !important;
    position: relative !important;
    text-align: center !important;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;

    /* Stagger entrance animations support */
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease !important;
  }

  .ai-testimonial-slider__card-{{ ai_gen_id }}.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-testimonial-slider__card-{{ ai_gen_id }}.is-visible:hover {
    transform: translateY(-10px) scale(1.02) !important;
    box-shadow: 0 30px 70px rgba(0,0,0,0.3) !important;
  }

  .ai-testimonial-slider__card-{{ ai_gen_id }}::before {
    content: "“" !important;
    font-size: 80px !important;
    color: #E30613 !important;
    opacity: 0.12 !important;
    position: absolute !important;
    top: 10px !important;
    left: 20px !important;
    font-family: Georgia, serif !important;
    line-height: 1 !important;
    pointer-events: none !important;
  }

  .ai-testimonial-slider__rating-wrap-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 16px;
  }

  .ai-testimonial-slider__stars-{{ ai_gen_id }} {
    display: flex !important;
    gap: 3px !important;
    justify-content: center !important;
    margin-bottom: 4px !important;
  }

  .ai-testimonial-slider__star-{{ ai_gen_id }} {
    width: 20px !important;
    height: 20px !important;
    fill: #f5a623 !important;
  }

  .ai-testimonial-rating-text-{{ ai_gen_id }} {
    font-size: 12px;
    color: #aaaaaa;
    font-weight: 500;
  }

  .ai-testimonial-slider__title-{{ ai_gen_id }} {
    font-size: 20px !important;
    font-weight: 800 !important;
    color: #111111 !important;
    margin: 0 0 12px 0 !important;
    text-align: center !important;
    line-height: 1.3;
  }

  .ai-testimonial-slider__text-{{ ai_gen_id }} {
    font-size: 15px !important;
    color: #555555 !important;
    line-height: 1.8 !important;
    font-style: italic !important;
    max-width: 480px !important;
    margin: 0 auto 24px auto !important;
    text-align: center !important;
    opacity: 1 !important;
  }

  .ai-testimonial-slider__profile-{{ ai_gen_id }} {
    display: flex !important;
    flex-direction: row !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 14px !important;
    margin-top: 0 !important;
  }

  .ai-testimonial-slider__image-wrapper-{{ ai_gen_id }} {
    width: 52px !important;
    height: 52px !important;
    border-radius: 50% !important;
    overflow: hidden !important;
    border: 3px solid #E30613 !important;
    box-shadow: 0 4px 12px rgba(227,6,19,0.25) !important;
    flex-shrink: 0;
  }

  .ai-testimonial-slider__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-testimonial-slider__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background: #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-testimonial-slider__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-testimonial-slider__profile-meta-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .ai-testimonial-slider__name-{{ ai_gen_id }} {
    font-size: 15px !important;
    font-weight: 700 !important;
    color: #111111 !important;
    margin: 0 !important;
    text-align: left !important;
    line-height: 1.2;
  }

  .ai-testimonial-verified-badge-{{ ai_gen_id }} {
    font-size: 11px;
    color: #E30613;
    font-weight: 600;
    margin-top: 3px;
    line-height: 1;
    text-align: left;
  }

  .ai-testimonial-slider__controls-{{ ai_gen_id }} {
    position: static !important;
    transform: none !important;
    display: flex !important;
    gap: 8px !important;
    justify-content: center !important;
    margin-top: 28px !important;
    z-index: 10 !important;
  }

  .ai-testimonial-slider__dot-{{ ai_gen_id }} {
    width: 8px !important;
    height: 8px !important;
    border-radius: 50% !important;
    background: rgba(255,255,255,0.4) !important;
    opacity: 1 !important;
    border: none !important;
    padding: 0 !important;
    cursor: pointer !important;
    transition: all 0.3s ease !important;
  }

  .ai-testimonial-slider__dot-{{ ai_gen_id }}.active {
    background: #ffffff !important;
    width: 24px !important;
    border-radius: 12px !important;
    transform: none !important;
  }

  .ai-testimonial-slider__arrows-{{ ai_gen_id }} {
    position: absolute !important;
    top: 55% !important;
    left: 50% !important;
    transform: translate(-50%, -50%) !important;
    width: 100% !important;
    max-width: 720px !important;
    display: flex !important;
    justify-content: space-between !important;
    padding: 0 20px !important;
    pointer-events: none !important;
    z-index: 10 !important;
    box-sizing: border-box;
  }

  .ai-testimonial-slider__arrow-{{ ai_gen_id }} {
    background: transparent !important;
    border: none !important;
    width: 44px !important;
    height: 44px !important;
    border-radius: 50% !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    cursor: pointer !important;
    pointer-events: auto !important;
    box-shadow: 0 4px 16px rgba(0,0,0,0.15) !important;
    transition: all 0.3s ease !important;
    opacity: 1 !important;
    padding: 0 !important;
  }

  .ai-testimonial-slider__arrow-{{ ai_gen_id }} svg {
    width: 20px !important;
    height: 20px !important;
    fill: #E30613 !important;
    transition: all 0.3s ease !important;
  }

  .ai-testimonial-slider__arrow-{{ ai_gen_id }}:hover {
    background: #E30613 !important;
  }

  .ai-testimonial-slider__arrow-{{ ai_gen_id }}:hover svg {
    fill: #ffffff !important;
  }

  @media screen and (min-width: 901px) {
    .ai-testimonial-slider-{{ ai_gen_id }} {
      padding: 80px 40px !important;
    }

    .ai-testimonial-slider__slides-{{ ai_gen_id }} {
      display: grid !important;
      grid-template-columns: repeat(3, 1fr) !important;
      gap: 30px !important;
      min-height: auto !important;
      max-width: 1200px !important;
      margin: 0 auto !important;
      position: relative !important;
    }

    .ai-testimonial-slider__slide-{{ ai_gen_id }} {
      position: relative !important;
      width: 100% !important;
      max-width: 100% !important;
      opacity: 1 !important;
      visibility: visible !important;
      transform: none !important;
      left: auto !important;
      top: auto !important;
    }

    .ai-testimonial-slider__slide-{{ ai_gen_id }}.active ~ .ai-testimonial-slider__slide-{{ ai_gen_id }} {
      transform: none !important;
    }

    .ai-testimonial-slider__arrows-{{ ai_gen_id }},
    .ai-testimonial-slider__controls-{{ ai_gen_id }} {
      display: none !important;
    }
  }

  @media screen and (max-width: 600px) {
    .ai-testimonial-slider-{{ ai_gen_id }} {
      padding: 50px 16px !important;
    }

    .ai-testimonial-slider__heading-{{ ai_gen_id }} {
      font-size: 26px !important;
    }

    .ai-testimonial-slider__card-{{ ai_gen_id }} {
      padding: 24px 20px !important;
    }

    .ai-testimonial-slider__text-{{ ai_gen_id }} {
      font-size: 14px !important;
    }

    .ai-testimonial-slider__slides-{{ ai_gen_id }} {
      min-height: 290px !important;
    }

    .ai-testimonial-slider__arrows-{{ ai_gen_id }} {
      max-width: 100% !important;
      padding: 0 10px !important;
      top: 60% !important;
    }

    .ai-testimonial-slider__arrow-{{ ai_gen_id }} {
      width: 36px !important;
      height: 36px !important;
    }
  }
{% endstyle %}

<testimonial-slider-{{ ai_gen_id }} class="ai-testimonial-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-testimonial-circle-1-{{ ai_gen_id }}"></div>
  <div class="ai-testimonial-circle-2-{{ ai_gen_id }}"></div>

  <div class="ai-testimonial-header-{{ ai_gen_id }}">
    <h2 class="ai-testimonial-slider__heading-{{ ai_gen_id }}">
      {{ block.settings.heading }}
    </h2>
    <div class="ai-testimonial-heading-accent-{{ ai_gen_id }}"></div>
    <p class="ai-testimonial-subtitle-{{ ai_gen_id }}">What our customers are saying</p>
  </div>

  <div class="ai-testimonial-slider__slides-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      {% liquid
        assign review_title_key = 'review_title_' | append: i
        assign review_text_key = 'review_text_' | append: i
        assign customer_name_key = 'customer_name_' | append: i
        assign customer_image_key = 'customer_image_' | append: i

        assign review_title = block.settings[review_title_key]
        assign review_text = block.settings[review_text_key]
        assign customer_name = block.settings[customer_name_key]
        assign customer_image = block.settings[customer_image_key]
      %}

      <div class="ai-testimonial-slider__slide-{{ ai_gen_id }} {% if i == 1 %}active{% endif %}" data-slide="{{ i }}">
        <div class="ai-testimonial-slider__card-{{ ai_gen_id }}">
          <div class="ai-testimonial-slider__rating-wrap-{{ ai_gen_id }}">
            <div class="ai-testimonial-slider__stars-{{ ai_gen_id }}">
              {% for star in (1..5) %}
                <svg class="ai-testimonial-slider__star-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              {% endfor %}
            </div>
            <div class="ai-testimonial-rating-text-{{ ai_gen_id }}">(5/5)</div>
          </div>

          <h3 class="ai-testimonial-slider__title-{{ ai_gen_id }}">
            {{ review_title }}
          </h3>

          <p class="ai-testimonial-slider__text-{{ ai_gen_id }}">
            {{ review_text }}
          </p>

          <div class="ai-testimonial-slider__profile-{{ ai_gen_id }}">
            <div class="ai-testimonial-slider__image-wrapper-{{ ai_gen_id }}">
              {% if customer_image %}
                <img
                  src="{{ customer_image | image_url: width: 200 }}"
                  alt="{{ customer_name | escape }}"
                  class="ai-testimonial-slider__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="200"
                  height="200"
                >
              {% else %}
                <div class="ai-testimonial-slider__image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-testimonial-slider__profile-meta-{{ ai_gen_id }}">
              <p class="ai-testimonial-slider__name-{{ ai_gen_id }}">
                {{ customer_name }}
              </p>
              <div class="ai-testimonial-verified-badge-{{ ai_gen_id }}">Verified Buyer ✓</div>
            </div>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>

  <div class="ai-testimonial-slider__arrows-{{ ai_gen_id }}">
    <button class="ai-testimonial-slider__arrow-{{ ai_gen_id }} ai-testimonial-slider__arrow-prev-{{ ai_gen_id }}" aria-label="Previous testimonial">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M15 18l-6-6 6-6"/>
      </svg>
    </button>
    <button class="ai-testimonial-slider__arrow-{{ ai_gen_id }} ai-testimonial-slider__arrow-next-{{ ai_gen_id }}" aria-label="Next testimonial">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M9 18l6-6-6-6"/>
      </svg>
    </button>
  </div>

  <div class="ai-testimonial-slider__controls-{{ ai_gen_id }}">
    {% for i in (1..3) %}
      <button class="ai-testimonial-slider__dot-{{ ai_gen_id }} {% if i == 1 %}active{% endif %}" data-slide="{{ i }}" aria-label="Go to slide {{ i }}"></button>
    {% endfor %}
  </div>
</testimonial-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class TestimonialSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 1;
        this.totalSlides = 3;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slides = this.querySelectorAll('.ai-testimonial-slider__slide-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-testimonial-slider__dot-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-testimonial-slider__arrow-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-testimonial-slider__arrow-next-{{ ai_gen_id }}');

        this.setupEventListeners();
        this.startAutoplay();
        this.initScrollAnimation();
      }

      initScrollAnimation() {
        const cards = this.querySelectorAll('.ai-testimonial-slider__card-{{ ai_gen_id }}');
        if ('IntersectionObserver' in window) {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                cards.forEach((card, index) => {
                  setTimeout(() => {
                    card.classList.add('is-visible');
                  }, index * 150);
                });
                observer.unobserve(entry.target);
              }
            });
          }, { threshold: 0.1 });
          observer.observe(this);
        } else {
          cards.forEach(card => card.classList.add('is-visible'));
        }
      }

      setupEventListeners() {
        this.dots.forEach((dot) => {
          dot.addEventListener('click', () => {
            const slideNumber = parseInt(dot.getAttribute('data-slide'));
            this.goToSlide(slideNumber);
            this.resetAutoplay();
          });
        });

        this.prevButton.addEventListener('click', () => {
          this.previousSlide();
          this.resetAutoplay();
        });

        this.nextButton.addEventListener('click', () => {
          this.nextSlide();
          this.resetAutoplay();
        });
      }

      goToSlide(slideNumber) {
        this.slides.forEach((slide) => {
          slide.classList.remove('active');
        });

        this.dots.forEach((dot) => {
          dot.classList.remove('active');
        });

        const targetSlide = this.querySelector(`.ai-testimonial-slider__slide-{{ ai_gen_id }}[data-slide="${slideNumber}"]`);
        const targetDot = this.querySelector(`.ai-testimonial-slider__dot-{{ ai_gen_id }}[data-slide="${slideNumber}"]`);
        if (targetSlide) {
          targetSlide.classList.add('active');
        }

        if (targetDot) {
          targetDot.classList.add('active');
        }

        this.currentSlide = slideNumber;
      }

      nextSlide() {
        const nextSlideNumber = this.currentSlide === this.totalSlides ? 1 : this.currentSlide + 1;
        this.goToSlide(nextSlideNumber);
      }

      previousSlide() {
        const prevSlideNumber = this.currentSlide === 1 ? this.totalSlides : this.currentSlide - 1;
        this.goToSlide(prevSlideNumber);
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, 5000);
      }

      resetAutoplay() {
        clearInterval(this.autoplayInterval);
        this.startAutoplay();
      }

      disconnectedCallback() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
        }
      }
    }

    customElements.define('testimonial-slider-{{ ai_gen_id }}', TestimonialSlider{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Testimonial slider",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Verified, Honest Reviews"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 18,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#1a7a7a"
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#d4e8f0"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card text color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "shadow_opacity",
      "label": "Shadow opacity",
      "min": 0,
      "max": 0.5,
      "step": 0.1,
      "default": 0.2
    },
    {
      "type": "range",
      "id": "review_title_size",
      "label": "Title size",
      "min": 18,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 26
    },
    {
      "type": "range",
      "id": "review_text_size",
      "label": "Text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Stars"
    },
    {
      "type": "range",
      "id": "star_size",
      "label": "Star size",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#ffc107"
