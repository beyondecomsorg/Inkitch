            "verified_label": "Verified Buyer ✓"
          }
        },
        {
          "type": "testimonial-item",
          "settings": {
            "rating": 5,
            "quote": "Brilliant quality for the price. No rust, no warping — still looks brand new after months of daily use.",
            "customer_name": "Rahul M.",
            "verified_label": "Verified Buyer ✓"
          }
        },
        {
          "type": "testimonial-item",
          "settings": {
            "rating": 5,
