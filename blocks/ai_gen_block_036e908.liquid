{% doc %}
  @prompt Testimonial carousel section for inKitch — block-based repeatable testimonials,
  auto-sliding carousel, red gradient background, white cards with star ratings.
  Desktop: 3 cards per page with smooth sliding transition, arrows + dot pagination.
  Mobile: 1 card at a time with same arrow/dot controls.
  Each testimonial is a nested testimonial-item block that renders its own card HTML.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  /* ── Outer section ───────────────────────────────────────────────────── */
  .ai-testimonial-slider-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: linear-gradient(135deg, #8b0000 0%, #c0000f 40%, #E30613 100%) !important;
    padding: 70px 24px !important;
    position: relative !important;
    overflow: hidden !important;
    box-sizing: border-box;
  }

  .ai-testimonial-slider-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background-image: repeating-linear-gradient(
      45deg, rgba(255,255,255,0.03) 0px,
      rgba(255,255,255,0.03) 1px, transparent 1px, transparent 12px
    ) !important;
    pointer-events: none;
    z-index: 1;
  }

  .ai-testimonial-circle-1-{{ ai_gen_id }} {
    position: absolute; top: -80px; left: -80px;
    width: 300px; height: 300px; border-radius: 50%;
    background: rgba(255,255,255,0.04); pointer-events: none; z-index: 1;
  }
  .ai-testimonial-circle-2-{{ ai_gen_id }} {
    position: absolute; bottom: -60px; right: -60px;
    width: 250px; height: 250px; border-radius: 50%;
    background: rgba(255,255,255,0.04); pointer-events: none; z-index: 1;
  }

  /* ── Header ─────────────────────────────────────────────────────────── */
  .ai-testimonial-header-{{ ai_gen_id }} {
    position: relative; z-index: 2; text-align: center; margin-bottom: 50px;
  }
  .ai-testimonial-slider__heading-{{ ai_gen_id }} {
    font-size: 34px !important; font-weight: 800 !important;
    color: #ffffff !important; text-align: center !important;
    margin: 0 !important; text-shadow: 0 2px 8px rgba(0,0,0,0.2) !important;
    line-height: 1.2; font-family: inherit;
  }
  .ai-testimonial-heading-accent-{{ ai_gen_id }} {
    width: 60px; height: 3px; background-color: #ffffff;
    opacity: 0.6; margin: 10px auto 0;
  }
  .ai-testimonial-subtitle-{{ ai_gen_id }} {
    color: rgba(255,255,255,0.75); font-size: 14px;
    margin-top: 10px; margin-bottom: 0; text-align: center;
  }

  /* ── Viewport + track (JS injects .ikt-slides-track inside) ─────────── */
  .ai-testimonial-slides-{{ ai_gen_id }} {
    position: relative; z-index: 2;
    overflow: hidden;
    /* height is managed by JS after build */
  }

  .ikt-slides-track {
    display: flex;
    will-change: transform;
    transition: transform 0.55s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Each page = one viewport-width strip */
  .ikt-slides-page {
    min-width: 100%;
    box-sizing: border-box;
    display: flex;
    gap: 0;
    align-items: stretch;
  }

  /* Each slide inside a page */
  .ikt-testimonial-slide {
    box-sizing: border-box;
    flex-shrink: 0;
    /* width set by JS (100% mobile, 33.33% desktop) */
    padding: 8px 12px;
    /* entrance animation on page turn */
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  /* ── Card ────────────────────────────────────────────────────────────── */
  .ikt-testimonial-card {
    background: #ffffff !important; border-radius: 20px !important;
    padding: 36px 32px !important; box-shadow: 0 20px 60px rgba(0,0,0,0.2) !important;
    height: 100%;
    position: relative !important; text-align: center !important;
    box-sizing: border-box; display: flex; flex-direction: column;
    align-items: center; gap: 0;
    opacity: 0; transform: scale(0.96) translateY(20px);
    transition: opacity 0.55s cubic-bezier(0.16,1,0.3,1), transform 0.55s cubic-bezier(0.16,1,0.3,1), box-shadow 0.3s ease !important;
  }
  .ikt-testimonial-card.is-visible {
    opacity: 1; transform: scale(1) translateY(0);
  }
  .ikt-testimonial-card.is-visible:hover {
    transform: translateY(-8px) scale(1.02) !important;
    box-shadow: 0 30px 70px rgba(0,0,0,0.3) !important;
  }
  .ikt-testimonial-card::before {
    content: "\201C" !important; font-size: 80px !important;
    color: #E30613 !important; opacity: 0.12 !important;
    position: absolute !important; top: 10px !important; left: 20px !important;
    font-family: Georgia, serif !important; line-height: 1 !important;
    pointer-events: none !important;
  }

  /* ── Stars ──────────────────────────────────────────────────────────── */
  .ikt-testimonial-rating-wrap {
    display: flex; flex-direction: column; align-items: center; margin-bottom: 16px;
  }
  .ikt-testimonial-stars {
    display: flex !important; gap: 3px !important;
    justify-content: center !important; margin-bottom: 4px !important;
  }
  .ikt-testimonial-star {
    width: 20px !important; height: 20px !important; fill: #f5a623 !important;
  }
  .ikt-testimonial-star.empty { fill: #dddddd !important; }
  .ikt-testimonial-rating-text { font-size: 12px; color: #aaaaaa; font-weight: 500; }

  /* ── Quote text ──────────────────────────────────────────────────────── */
  .ikt-testimonial-text {
    font-size: 15px !important; color: #555555 !important;
    line-height: 1.8 !important; font-style: italic !important;
    margin: 0 auto 24px auto !important;
    text-align: center !important; flex-grow: 1;
  }

  /* ── Profile row ─────────────────────────────────────────────────────── */
  .ikt-testimonial-profile {
    display: flex !important; flex-direction: row !important;
    align-items: center !important; justify-content: center !important;
    gap: 14px !important; margin-top: 0 !important; width: 100%;
  }
  .ikt-testimonial-avatar-wrap {
    width: 52px !important; height: 52px !important; border-radius: 50% !important;
    overflow: hidden !important; border: 3px solid #E30613 !important;
    box-shadow: 0 4px 12px rgba(227,6,19,0.25) !important; flex-shrink: 0;
  }
  .ikt-testimonial-avatar { width: 100%; height: 100%; object-fit: cover; }
  .ikt-testimonial-avatar-placeholder {
    width: 100%; height: 100%; background: #f0f0f0;
    display: flex; align-items: center; justify-content: center;
  }
  .ikt-testimonial-avatar-placeholder svg { width: 60%; height: 60%; opacity: 0.3; }
  .ikt-testimonial-meta {
    display: flex; flex-direction: column; align-items: flex-start;
  }
  .ikt-testimonial-name {
    font-size: 15px !important; font-weight: 700 !important;
    color: #111111 !important; margin: 0 !important;
    text-align: left !important; line-height: 1.2;
  }
  .ikt-testimonial-verified {
    font-size: 11px; color: #E30613; font-weight: 600;
    margin-top: 3px; line-height: 1; text-align: left;
  }

  /* ── Arrows ─────────────────────────────────────────────────────────── */
  .ai-testimonial-arrows-{{ ai_gen_id }} {
    display: flex !important; justify-content: center !important;
    gap: 16px !important; margin-top: 28px !important;
    z-index: 10 !important; position: relative;
  }
  .ai-testimonial-arrow-{{ ai_gen_id }} {
    background: rgba(255,255,255,0.15) !important; border: 2px solid rgba(255,255,255,0.3) !important;
    width: 44px !important; height: 44px !important; border-radius: 50% !important;
    display: flex !important; align-items: center !important;
    justify-content: center !important; cursor: pointer !important;
    transition: all 0.3s ease !important; padding: 0 !important;
  }
  .ai-testimonial-arrow-{{ ai_gen_id }} svg {
    width: 20px !important; height: 20px !important; stroke: #ffffff !important;
    transition: all 0.3s ease !important;
  }
  .ai-testimonial-arrow-{{ ai_gen_id }}:hover {
    background: #ffffff !important; border-color: #ffffff !important;
  }
  .ai-testimonial-arrow-{{ ai_gen_id }}:hover svg { stroke: #E30613 !important; }
  .ai-testimonial-arrow-{{ ai_gen_id }}:disabled {
    opacity: 0.35 !important; cursor: not-allowed !important;
  }

  /* ── Nav dots ────────────────────────────────────────────────────────── */
  .ai-testimonial-dots-{{ ai_gen_id }} {
    display: flex !important; gap: 8px !important;
    justify-content: center !important; margin-top: 16px !important;
    z-index: 10 !important; position: relative;
  }
  .ai-testimonial-dot-{{ ai_gen_id }} {
    width: 8px !important; height: 8px !important; border-radius: 50% !important;
    background: rgba(255,255,255,0.4) !important; border: none !important;
    padding: 0 !important; cursor: pointer !important;
    transition: all 0.3s ease !important;
  }
  .ai-testimonial-dot-{{ ai_gen_id }}.active {
    background: #ffffff !important; width: 24px !important;
    border-radius: 12px !important;
  }

  /* ── Desktop adjustments ─────────────────────────────────────────────── */
  @media screen and (min-width: 901px) {
    .ai-testimonial-slider-{{ ai_gen_id }} { padding: 80px 40px !important; }
    .ai-testimonial-slides-{{ ai_gen_id }} {
      max-width: 1200px;
      margin: 0 auto;
    }
  }

  /* ── Mobile tweaks ───────────────────────────────────────────────────── */
  @media screen and (max-width: 600px) {
    .ai-testimonial-slider-{{ ai_gen_id }} { padding: 50px 16px !important; }
    .ai-testimonial-slider__heading-{{ ai_gen_id }} { font-size: 26px !important; }
    .ikt-testimonial-card { padding: 24px 20px !important; }
    .ikt-testimonial-text { font-size: 14px !important; }
  }
{% endstyle %}

<testimonial-slider-{{ ai_gen_id }}
  class="ai-testimonial-slider-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-testimonial-circle-1-{{ ai_gen_id }}"></div>
  <div class="ai-testimonial-circle-2-{{ ai_gen_id }}"></div>

  <div class="ai-testimonial-header-{{ ai_gen_id }}">
    <h2 class="ai-testimonial-slider__heading-{{ ai_gen_id }}">
      {{ block.settings.heading }}
    </h2>
    <div class="ai-testimonial-heading-accent-{{ ai_gen_id }}"></div>
    <p class="ai-testimonial-subtitle-{{ ai_gen_id }}">Real reviews from real inKitch homes.</p>
  </div>

  <div class="ai-testimonial-slides-{{ ai_gen_id }}">
    {% content_for 'blocks' %}
  </div>

  <div class="ai-testimonial-arrows-{{ ai_gen_id }}">
    <button class="ai-testimonial-arrow-{{ ai_gen_id }} js-prev" aria-label="Previous">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M15 18l-6-6 6-6"/>
      </svg>
    </button>
    <button class="ai-testimonial-arrow-{{ ai_gen_id }} js-next" aria-label="Next">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M9 18l6-6-6-6"/>
      </svg>
    </button>
  </div>

  <div class="ai-testimonial-dots-{{ ai_gen_id }}"></div>
</testimonial-slider-{{ ai_gen_id }}>

<script>
  (function() {
    if (customElements.get('testimonial-slider-{{ ai_gen_id }}')) return;

    const DESKTOP_BP  = 901;  // px — cards per page switches at this breakpoint
    const AUTOPLAY_MS = 3000;

    class TestimonialSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentPage  = 0;
        this.timer        = null;
        this.pauseTimeout = null;
        this.paused       = false;
        this.pages        = [];  // array of page DOM nodes
        this.track        = null;
      }

      /* ── Lifecycle ─────────────────────────────────────────────────── */
      connectedCallback() {
        this.viewport   = this.querySelector('.ai-testimonial-slides-{{ ai_gen_id }}');
        this.dotsEl     = this.querySelector('.ai-testimonial-dots-{{ ai_gen_id }}');
        this.prevBtn    = this.querySelector('.js-prev');
        this.nextBtn    = this.querySelector('.js-next');

        this.rawSlides = Array.from(this.querySelectorAll('.ikt-testimonial-slide'));
        if (this.rawSlides.length === 0) return;

        this.build();
        this.bindEvents();
        this.goTo(0, false);
        this.startAutoplay();
        this.initReveal();

        // Rebuild on resize when crossing DESKTOP_BP
        this._resizeHandler = this._onResize.bind(this);
        window.addEventListener('resize', this._resizeHandler, { passive: true });
      }

      disconnectedCallback() {
        clearInterval(this.timer);
        clearTimeout(this.pauseTimeout);
        window.removeEventListener('resize', this._resizeHandler);
      }

      /* ── Build track ──────────────────────────────────────────────── */
      cardsPerPage() {
        return window.innerWidth >= DESKTOP_BP ? 3 : 1;
      }

      build() {
        const cpp = this.cardsPerPage();
        this._lastCpp = cpp;

        // Create track
        const track = document.createElement('div');
        track.className = 'ikt-slides-track';
        this.track = track;
        this.pages = [];

        // Chunk slides into pages
        const slides = this.rawSlides;
        for (let i = 0; i < slides.length; i += cpp) {
          const pageEl = document.createElement('div');
          pageEl.className = 'ikt-slides-page';
          const chunk = slides.slice(i, i + cpp);
          chunk.forEach(s => {
            s.style.width = (100 / cpp) + '%';
            pageEl.appendChild(s);
          });
          track.appendChild(pageEl);
          this.pages.push(pageEl);
        }

        this.viewport.innerHTML = '';
        this.viewport.appendChild(track);

        this.buildDots();
        if (this.currentPage >= this.pages.length) this.currentPage = 0;
      }

      _onResize() {
        const cpp = this.cardsPerPage();
        if (cpp === this._lastCpp) return;   // breakpoint not crossed
        // Rebuild track for new cpp
        const prevPage = this.currentPage;
        // Put all slides back flat before rebuild
        const allSlides = [];
        this.pages.forEach(p => allSlides.push(...p.querySelectorAll('.ikt-testimonial-slide')));
        this.rawSlides = allSlides;
        this.build();
        this.goTo(Math.min(prevPage, this.pages.length - 1), false);
      }

      /* ── Dots ─────────────────────────────────────────────────────── */
      buildDots() {
        if (!this.dotsEl) return;
        this.dotsEl.innerHTML = '';
        if (this.pages.length <= 1) return;
        this.pages.forEach((_, i) => {
          const btn = document.createElement('button');
          btn.className = 'ai-testimonial-dot-{{ ai_gen_id }}';
          btn.setAttribute('aria-label', 'Page ' + (i + 1));
          btn.addEventListener('click', () => { this.goTo(i); this.resetAutoplay(); });
          this.dotsEl.appendChild(btn);
        });
        this.dots = Array.from(this.dotsEl.querySelectorAll('.ai-testimonial-dot-{{ ai_gen_id }}'));
      }

      /* ── Navigation ───────────────────────────────────────────────── */
      goTo(pageIndex, animate = true) {
        if (!animate) this.track.style.transition = 'none';

        this.track.style.transform = `translateX(-${pageIndex * 100}%)`;

        if (!animate) {
          // Force reflow then re-enable transition
          this.track.getBoundingClientRect();
          this.track.style.transition = '';
        }

        // Animate incoming cards: scale + fade entrance
        this.pages.forEach((page, pi) => {
          const cards = page.querySelectorAll('.ikt-testimonial-card');
          if (pi === pageIndex) {
            cards.forEach((c, ci) => {
              c.style.opacity = '0';
              c.style.transform = 'scale(0.96) translateY(16px)';
              setTimeout(() => {
                c.style.opacity = '';
                c.style.transform = '';
              }, 80 + ci * 80);
            });
          }
        });

        // Update dots
        if (this.dots) {
          this.dots.forEach((d, i) => d.classList.toggle('active', i === pageIndex));
        }

        // Update arrow disabled state
        if (this.prevBtn) this.prevBtn.disabled = false;
        if (this.nextBtn) this.nextBtn.disabled = false;

        this.currentPage = pageIndex;
      }

      next() { this.goTo((this.currentPage + 1) % this.pages.length); }
      prev() { this.goTo((this.currentPage - 1 + this.pages.length) % this.pages.length); }

      /* ── Events ───────────────────────────────────────────────────── */
      bindEvents() {
        if (this.prevBtn) this.prevBtn.addEventListener('click', () => { this.prev(); this.resetAutoplay(); });
        if (this.nextBtn) this.nextBtn.addEventListener('click', () => { this.next(); this.resetAutoplay(); });

        this.addEventListener('mouseenter', () => { this.paused = true; });
        this.addEventListener('mouseleave', () => {
          clearTimeout(this.pauseTimeout);
          this.pauseTimeout = setTimeout(() => { this.paused = false; }, 3000);
        });
        this.addEventListener('touchstart', () => { this.paused = true; }, { passive: true });
        this.addEventListener('touchend', () => {
          clearTimeout(this.pauseTimeout);
          this.pauseTimeout = setTimeout(() => { this.paused = false; }, 3000);
        }, { passive: true });
      }

      /* ── Autoplay ─────────────────────────────────────────────────── */
      startAutoplay() {
        this.paused = false;
        this.timer = setInterval(() => { if (!this.paused) this.next(); }, AUTOPLAY_MS);
      }

      resetAutoplay() { clearInterval(this.timer); this.startAutoplay(); }

      /* ── Scroll reveal ────────────────────────────────────────────── */
      initReveal() {
        const cards = this.querySelectorAll('.ikt-testimonial-card');
        if ('IntersectionObserver' in window) {
          const obs = new IntersectionObserver(entries => {
            entries.forEach(e => {
              if (e.isIntersecting) {
                cards.forEach((c, i) => setTimeout(() => c.classList.add('is-visible'), i * 120));
                obs.unobserve(e.target);
              }
            });
          }, { threshold: 0.1 });
          obs.observe(this);
        } else {
          cards.forEach(c => c.classList.add('is-visible'));
        }
      }
    }

    customElements.define('testimonial-slider-{{ ai_gen_id }}', TestimonialSlider{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Testimonial Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Verified, Honest Reviews"
    }
  ],
  "blocks": [
    {
      "type": "testimonial-item"
    }
  ],
  "presets": [
