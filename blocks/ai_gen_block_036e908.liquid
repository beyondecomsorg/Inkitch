      "name": "Testimonial Slider",
      "blocks": [
        {
          "type": "testimonial-item",
          "settings": {
            "rating": 5,
            "quote": "The build quality is solid and everything fits perfectly. Worth every rupee — my kitchen feels so much more organised now.",
