{% doc %}
  @prompt
    Create a custom section called "Video Showcase Slider". It should display a full-width horizontal slider with 3 video cards visible at a time. The section has a dark black or very dark gray background (hex #0A0A0A) to make the videos look cinematic and premium.
    Each slide is a tall rectangular video card with slightly rounded corners (border-radius 12px). The video inside each card is muted, has no controls, and plays automatically only when the user hovers their mouse over that card. When the user moves the mouse away, the video pauses and resets. The video should fill the entire card (object-fit cover) so it looks like a full bleed visual.
    On each card, overlay a gradient from transparent at the top to dark black at the bottom. On top of this gradient at the bottom of the card, show a bold white heading and a short white subtitle text. When the card is hovered, the text smoothly fades out or slides down so the full video is visible without distraction.
    The slider should have smooth sliding animation with left and right arrow buttons in a minimal circle style (white icon, semi-transparent dark background) positioned on the left and right edges of the section. Add dot indicators at the bottom center of the section showing which slide is active.
    All 3 video files should be uploadable from the Shopify theme editor (accept MP4 format). The heading and subtitle text on each card should also be editable from the theme editor. On mobile, show 1 card at a time and make the arrows larger and easier to tap.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-showcase-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    position: relative;
    overflow: hidden;
  }

  .ai-video-showcase-container-{{ ai_gen_id }} {
    position: relative;
    max-width: 100%;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-video-showcase-slider-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-video-showcase-slider-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease;
    gap: {{ block.settings.card_gap }}px;
  }

  .ai-video-showcase-slide-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - (2 * {{ block.settings.card_gap }}px)) / 3);
    position: relative;
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    height: {{ block.settings.card_height }}px;
    background-color: #1a1a1a;
  }

  .ai-video-showcase-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .ai-video-showcase-video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-video-showcase-gradient-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 60%;
    background: linear-gradient(to bottom, transparent 0%, rgba(0, 0, 0, 0.9) 100%);
    pointer-events: none;
    z-index: 1;
  }

  .ai-video-showcase-content-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 30px;
    z-index: 2;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .ai-video-showcase-slide-{{ ai_gen_id }}:hover .ai-video-showcase-content-{{ ai_gen_id }} {
    opacity: 0;
    transform: translateY(20px);
  }

  .ai-video-showcase-heading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    margin: 0 0 8px 0;
    line-height: 1.2;
  }

  .ai-video-showcase-subtitle-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.subtitle_size }}px;
    margin: 0;
    opacity: 0.9;
    line-height: 1.4;
  }

  .ai-video-showcase-arrow-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: {{ block.settings.arrow_size }}px;
    height: {{ block.settings.arrow_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.arrow_background }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: opacity 0.3s ease;
  }

  .ai-video-showcase-arrow-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-video-showcase-arrow-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-video-showcase-arrow-left-{{ ai_gen_id }} {
    left: 20px;
  }

  .ai-video-showcase-arrow-right-{{ ai_gen_id }} {
    right: 20px;
  }

  .ai-video-showcase-arrow-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
    fill: {{ block.settings.arrow_color }};
  }

  .ai-video-showcase-dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 30px;
  }

  .ai-video-showcase-dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.3;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .ai-video-showcase-dot-{{ ai_gen_id }}.active {
    opacity: 1;
    transform: scale(1.2);
  }

  .ai-video-showcase-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-video-showcase-placeholder-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    opacity: 0.3;
  }

  .ai-video-showcase-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #999;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-video-showcase-slide-{{ ai_gen_id }} {
      flex: 0 0 100%;
      height: {{ block.settings.card_height_mobile }}px;
    }

    .ai-video-showcase-arrow-{{ ai_gen_id }} {
      width: {{ block.settings.arrow_size_mobile }}px;
      height: {{ block.settings.arrow_size_mobile }}px;
    }

    .ai-video-showcase-arrow-{{ ai_gen_id }} svg {
      width: 32px;
      height: 32px;
    }

    .ai-video-showcase-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-video-showcase-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }

    .ai-video-showcase-content-{{ ai_gen_id }} {
      padding: 20px;
    }
  }
{% endstyle %}

<video-showcase-slider-{{ ai_gen_id }}
  class="ai-video-showcase-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-video-showcase-container-{{ ai_gen_id }}">
    <div class="ai-video-showcase-slider-wrapper-{{ ai_gen_id }}">
      <div class="ai-video-showcase-slider-{{ ai_gen_id }}">
        {% for i in (1..3) %}
          {% liquid
            assign video_key = 'video_' | append: i
            assign heading_key = 'heading_' | append: i
            assign subtitle_key = 'subtitle_' | append: i
            assign video = block.settings[video_key]
            assign heading = block.settings[heading_key]
            assign subtitle = block.settings[subtitle_key]
          %}

          <div class="ai-video-showcase-slide-{{ ai_gen_id }}" data-slide="{{ i }}">
            <div class="ai-video-showcase-video-wrapper-{{ ai_gen_id }}">
              {% if video %}
                <video
                  class="ai-video-showcase-video-{{ ai_gen_id }}"
                  muted
                  playsinline
                  loop
                  preload="metadata"
                  data-video-index="{{ i }}"
                >
                  <source src="{{ video }}" type="video/mp4">
                </video>
              {% else %}
                <div class="ai-video-showcase-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                  <div class="ai-video-showcase-empty-state-{{ ai_gen_id }}">
                    Add video {{ i }}
                  </div>
                </div>
              {% endif %}
            </div>

            <div class="ai-video-showcase-gradient-{{ ai_gen_id }}"></div>

            <div class="ai-video-showcase-content-{{ ai_gen_id }}">
              {% if heading != blank %}
                <h3 class="ai-video-showcase-heading-{{ ai_gen_id }}">{{ heading }}</h3>
              {% endif %}
              {% if subtitle != blank %}
                <p class="ai-video-showcase-subtitle-{{ ai_gen_id }}">{{ subtitle }}</p>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>

      <button
        class="ai-video-showcase-arrow-{{ ai_gen_id }} ai-video-showcase-arrow-left-{{ ai_gen_id }}"
        aria-label="Previous slide"
        data-direction="prev"
      >
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M15 18l-6-6 6-6"/>
        </svg>
      </button>

      <button
        class="ai-video-showcase-arrow-{{ ai_gen_id }} ai-video-showcase-arrow-right-{{ ai_gen_id }}"
        aria-label="Next slide"
        data-direction="next"
      >
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M9 18l6-6-6-6"/>
        </svg>
      </button>
    </div>

    <div class="ai-video-showcase-dots-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        <button
          class="ai-video-showcase-dot-{{ ai_gen_id }} {% if i == 1 %}active{% endif %}"
          aria-label="Go to slide {{ i }}"
          data-slide-index="{{ i | minus: 1 }}"
        ></button>
      {% endfor %}
    </div>
  </div>
</video-showcase-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoShowcaseSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.totalSlides = 3;
        this.isTransitioning = false;
        this.isMobile = window.innerWidth <= 749;
        this.slidesPerView = this.isMobile ? 1 : 3;
      }

      connectedCallback() {
        this.slider = this.querySelector('.ai-video-showcase-slider-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-video-showcase-slide-{{ ai_gen_id }}');
        this.videos = this.querySelectorAll('.ai-video-showcase-video-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-video-showcase-arrow-left-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-video-showcase-arrow-right-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-video-showcase-dot-{{ ai_gen_id }}');

        this.setupEventListeners();
        this.updateSlider();
        this.handleResize();
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.navigate('prev'));
        this.nextButton.addEventListener('click', () => this.navigate('next'));

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });

        this.slides.forEach((slide, index) => {
          const video = slide.querySelector('.ai-video-showcase-video-{{ ai_gen_id }}');
          if (video) {
            slide.addEventListener('mouseenter', () => {
              video.currentTime = 0;
              video.play().catch(() => {});
            });

            slide.addEventListener('mouseleave', () => {
              video.pause();
              video.currentTime = 0;
            });
          }
        });

        window.addEventListener('resize', () => this.handleResize());
      }

      handleResize() {
        const wasMobile = this.isMobile;
        this.isMobile = window.innerWidth <= 749;
        this.slidesPerView = this.isMobile ? 1 : 3;

        if (wasMobile !== this.isMobile) {
          this.currentIndex = 0;
          this.updateSlider();
        }
      }

      navigate(direction) {
        if (this.isTransitioning) return;

        if (direction === 'prev') {
          this.currentIndex = Math.max(0, this.currentIndex - 1);
        } else {
          const maxIndex = this.isMobile ? this.totalSlides - 1 : 0;
          this.currentIndex = Math.min(maxIndex, this.currentIndex + 1);
        }

        this.updateSlider();
      }

      goToSlide(index) {
        if (this.isTransitioning) return;
        this.currentIndex = index;
        this.updateSlider();
      }

      updateSlider() {
        this.isTransitioning = true;

        const slideWidth = this.slides[0].offsetWidth;
        const gap = {{ block.settings.card_gap }};
        const offset = this.currentIndex * (slideWidth + gap);

        this.slider.style.transform = `translateX(-${offset}px)`;

        this.dots.forEach((dot, index) => {
          if (index === this.currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });

        this.prevButton.disabled = this.currentIndex === 0;
        const maxIndex = this.isMobile ? this.totalSlides - 1 : 0;
        this.nextButton.disabled = this.currentIndex >= maxIndex;

        setTimeout(() => {
          this.isTransitioning = false;
        }, 500);
      }
    }

    customElements.define('video-showcase-slider-{{ ai_gen_id }}', VideoShowcaseSlider{{ ai_gen_id }});
  })();
</script>

