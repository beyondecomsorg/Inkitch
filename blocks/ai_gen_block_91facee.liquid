{% doc %}
  @prompt
    Here’s a clean React + Tailwind CSS + Framer Motion code for your Inkitch marketplace showcase section.
    
    ```jsx
    "use client";
    
    import { motion } from "framer-motion";
    
    const marketplaces = [
      {
        name: "Amazon",
        logo: "/logos/amazon.png",
        url: "https://amazon.in",
      },
      {
        name: "Flipkart",
        logo: "/logos/flipkart.png",
        url: "https://flipkart.com",
      },
      {
        name: "Meesho",
        logo: "/logos/meesho.png",
        url: "https://meesho.com",
      },
      {
        name: "Myntra",
        logo: "/logos/myntra.png",
        url: "https://myntra.com",
      },
      {
        name: "Ajio",
        logo: "/logos/ajio.png",
        url: "https://ajio.com",
      },
      {
        name: "Snapdeal",
        logo: "/logos/snapdeal.png",
        url: "https://snapdeal.com",
      },
      {
        name: "JioMart",
        logo: "/logos/jiomart.png",
        url: "https://jiomart.com",
      },
      {
        name: "Shopify",
        logo: "/logos/shopify.png",
        url: "https://shopify.com",
      },
    ];
    
    export default function MarketplaceShowcase() {
      return (
        <section className="py-20 overflow-hidden bg-white">
          <div className="text-center mb-12">
            <h2 className="text-4xl font-bold text-black">
              Available on Top Marketplaces
            </h2>
    
            <p className="text-gray-500 mt-4 text-lg">
              Shop Inkitch products across India’s leading platforms.
            </p>
          </div>
    
          <div className="relative">
            <motion.div
              className="flex gap-6 w-max"
              animate={{ x: ["0%", "-50%"] }}
              transition={{
                repeat: Infinity,
                duration: 20,
                ease: "linear",
              }}
            >
              {[...marketplaces, ...marketplaces].map((item, index) => (
                <a
                  key={index}
                  href={item.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  className="group"
                >
                  <div className="w-36 h-36 bg-white rounded-3xl border border-gray-200 shadow-sm flex flex-col items-center justify-center transition-all duration-300 hover:shadow-xl hover:-translate-y-2 hover:scale-105">
                    
                    <img
                      src={item.logo}
                      alt={item.name}
                      className="w-20 h-20 object-contain"
                    />
    
                    <p className="mt-3 text-sm font-medium text-gray-700">
                      {item.name}
                    </p>
                  </div>
                </a>
              ))}
            </motion.div>
    
            {/* Left Fade */}
            <div className="absolute top-0 left-0 w-32 h-full bg-gradient-to-r from-white to-transparent z-10"></div>
    
            {/* Right Fade */}
            <div className="absolute top-0 right-0 w-32 h-full bg-gradient-to-l from-white to-transparent z-10"></div>
          </div>
        </section>
      );
    }
    ```
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-marketplace-showcase-{{ ai_gen_id }} {
    display: block !important;
    padding: 60px 24px !important;
    overflow: hidden !important;
    background-color: #fafafa !important;

    width: 100% !important;
    position: relative !important;
    box-sizing: border-box !important;
  }

  .ai-marketplace-header-{{ ai_gen_id }} {
    text-align: center !important;
    margin-bottom: 40px !important;
    padding: 0 20px !important;
  }

  .ai-marketplace-title-{{ ai_gen_id }} {
    font-size: var(--font-size-h2) !important;
    font-weight: var(--font-weight-heading) !important;
    color: #111111 !important;
    text-align: center !important;
    margin: 0 !important;
    line-height: 1.2 !important;
  }

  .ai-marketplace-title-accent-{{ ai_gen_id }} {
    width: 60px !important;
    height: 3px !important;
    background-color: #E30613 !important;
    margin: 10px auto 0 !important;
  }

  .ai-marketplace-subtitle-{{ ai_gen_id }} {
    font-size: var(--font-size-body) !important;
    color: #888888 !important;
    margin-top: 8px !important;
    margin-bottom: 0 !important;
    text-align: center !important;
  }

  .ai-marketplace-carousel-wrapper-{{ ai_gen_id }} {
    position: relative !important;
    width: 100% !important;
    padding: 10px 0 !important;
    box-sizing: border-box !important;
  }

  /* Remove edge fades */
  .ai-marketplace-carousel-wrapper-{{ ai_gen_id }}::before,
  .ai-marketplace-carousel-wrapper-{{ ai_gen_id }}::after {
    content: none !important;
    display: none !important;
  }

  /* Center track and row spacing */
  .ai-marketplace-carousel-track-{{ ai_gen_id }} {
    display: flex !important;
    justify-content: center !important;
    align-items: center !important;
    gap: 32px !important;
    flex-wrap: nowrap !important;
    width: 100% !important;
    box-sizing: border-box !important;
  }

  .ai-marketplace-card-{{ ai_gen_id }} {
    flex-shrink: 0 !important;
    width: 130px !important;
    height: 130px !important;
    background-color: #ffffff !important;
    border-radius: 16px !important;
    border: 1.5px solid #f0f0f0 !important;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.07) !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 10px !important;
    text-decoration: none !important;
    cursor: pointer !important;
    transition: all 0.3s ease !important;
    padding: 20px 16px !important;
    box-sizing: border-box !important;
  }

  .ai-marketplace-card-{{ ai_gen_id }}:hover {
    border-color: #E30613 !important;
    box-shadow: 0 8px 28px rgba(227, 6, 19, 0.15) !important;
    transform: translateY(-6px) scale(1.03) !important;
  }

  .ai-marketplace-logo-wrapper-{{ ai_gen_id }} {
    width: 56px !important;
    height: 56px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    margin: 0 !important;
    padding: 0 !important;
    background: transparent !important;
    border-radius: 0 !important;
  }

  .ai-marketplace-logo-{{ ai_gen_id }} {
    width: 100% !important;
    height: 100% !important;
    object-fit: contain !important;
    background: transparent !important;
    border-radius: 0 !important;
    transition: transform 0.3s ease !important;
  }

  .ai-marketplace-card-{{ ai_gen_id }}:hover .ai-marketplace-logo-{{ ai_gen_id }} {
    transform: scale(1.08) !important;
  }

  .ai-marketplace-logo-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-marketplace-logo-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-marketplace-name-{{ ai_gen_id }} {
    font-size: var(--font-size-small) !important;
    font-weight: var(--font-weight-body) !important;
    color: #333333 !important;
    margin: 0 !important;
    text-align: center !important;
    transition: color 0.3s ease !important;
  }

  .ai-marketplace-card-{{ ai_gen_id }}:hover .ai-marketplace-name-{{ ai_gen_id }} {
    color: #E30613 !important;
  }

  @media screen and (max-width: 768px) {
    .ai-marketplace-carousel-track-{{ ai_gen_id }} {
      flex-wrap: wrap !important;
      gap: 16px !important;
      justify-content: center !important;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-marketplace-carousel-track-{{ ai_gen_id }} {
      display: flex !important;
      flex-direction: row !important;
      flex-wrap: nowrap !important;
      overflow-x: auto !important;
      overflow-y: hidden !important;
      scroll-snap-type: x mandatory !important;
      scroll-padding-left: 16px !important;
      -webkit-overflow-scrolling: touch !important;
      gap: 16px !important;
      justify-content: flex-start !important;
      padding: 10px 16px !important;
      margin-left: -16px !important;
      margin-right: -16px !important;
    }

    .ai-marketplace-carousel-track-{{ ai_gen_id }}::-webkit-scrollbar {
      display: none !important;
    }

    .ai-marketplace-card-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - 32px) / 3.2) !important;
      min-width: calc((100% - 32px) / 3.2) !important;
      scroll-snap-align: start !important;
    }
  }

  @media screen and (max-width: 600px) {
    .ai-marketplace-showcase-{{ ai_gen_id }} {
      padding: 40px 16px !important;
    }

    .ai-marketplace-card-{{ ai_gen_id }} {
      height: 110px !important;
      padding: 12px 10px !important;
      gap: 6px !important;
    }

    .ai-marketplace-logo-wrapper-{{ ai_gen_id }} {
      width: 48px !important;
      height: 48px !important;
    }

    /* Font size scaled dynamically via responsive CSS variable on mobile */
  }
{% endstyle %}

<div class="ai-marketplace-showcase-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-marketplace-header-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-marketplace-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    {% endif %}
    <div class="ai-marketplace-title-accent-{{ ai_gen_id }}"></div>
    {% if block.settings.subtitle != blank %}
      <p class="ai-marketplace-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
    {% endif %}
  </div>

  <div class="ai-marketplace-carousel-wrapper-{{ ai_gen_id }}">
    <div class="ai-marketplace-carousel-track-{{ ai_gen_id }}">
      {% for i in (1..8) %}
        {% liquid
          assign name_key = 'marketplace_' | append: i | append: '_name'
          assign logo_key = 'marketplace_' | append: i | append: '_logo'
          assign url_key = 'marketplace_' | append: i | append: '_url'
          assign enabled_key = 'marketplace_' | append: i | append: '_enabled'

          assign marketplace_name = block.settings[name_key]
          assign marketplace_logo = block.settings[logo_key]
          assign marketplace_url = block.settings[url_key]
          assign marketplace_enabled = block.settings[enabled_key]
        %}

        {% if marketplace_enabled %}
          <a
            href="{{ marketplace_url }}"
            class="ai-marketplace-card-{{ ai_gen_id }}"
            target="_blank"
            rel="noopener noreferrer"
            title="Shop on {{ marketplace_name | escape }}"
            {% if marketplace_name != blank %}
              aria-label="{{ marketplace_name }}"
            {% endif %}
          >
            <div class="ai-marketplace-logo-wrapper-{{ ai_gen_id }}">
              {% if marketplace_logo %}
                <img
                  src="{{ marketplace_logo | image_url: width: 160 }}"
                  alt="{{ marketplace_name | escape }}"
                  class="ai-marketplace-logo-{{ ai_gen_id }}"
                  loading="lazy"
                  width="80"
                  height="80"
                >
              {% else %}
                <div class="ai-marketplace-logo-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
            {% if marketplace_name != blank %}
              <p class="ai-marketplace-name-{{ ai_gen_id }}">{{ marketplace_name }}</p>
            {% endif %}
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

