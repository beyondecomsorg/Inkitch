{% doc %}
  @prompt
    A product card that includes the product image at the top, then the price and title below. Add a smooth holographic shimmer effect and a shadow., add multiple product options in slides
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-carousel-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    position: relative;
    overflow: hidden;
    background-color: #fafafa;
    padding-top:0px;
   
  }

  .ai-product-carousel-container-{{ ai_gen_id }} {
    position: relative;
    padding: 0 50px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-product-carousel-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.slide_gap }}px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 15px 5px;
  }

  .ai-product-carousel-track-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-product-carousel-slide-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - {{ block.settings.slide_gap | times: 2 }}px) / {{ block.settings.slides_per_view }});
    min-width: 0;
  }

  .ai-product-card-wrapper-{{ ai_gen_id }} {
    position: relative;
    background-color: #ffffff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.07);
    transition: all 0.3s ease;
    height: 100%;
    display: flex;
    flex-direction: column;
    border: 1px solid #f0f0f0;
  }

  .ai-product-card-wrapper-{{ ai_gen_id }}:hover {
    transform: translateY(-6px);
    border-color: #E30613;
    box-shadow: 0 8px 28px rgba(227,6,19,0.12);
  }

  .ai-product-card-image-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: #f8f8f8;
    height: auto;
    min-height: 280px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 16px 16px 0 0;
    padding: 16px;
  }

  .ai-product-card-image-{{ ai_gen_id }} {
    width: 100%;
    max-height: 300px;
    object-fit: contain;
    display: block;
    border-radius: 10px;
    transition: transform 0.4s ease;
  }

  .ai-product-card-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    position: relative;
  }

  .ai-product-card-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-product-card-badge-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    left: 12px;
    background-color: #E30613;
    color: #ffffff;
    font-weight: 700;
    font-size: 11px;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 6px;
    z-index: 3;
    letter-spacing: 0.5px;
    box-shadow: 0 2px 6px rgba(227,6,19,0.3);
  }

  .ai-product-card-shimmer-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 255, 255, 0) 20%,
      rgba(255, 0, 255, 0.3) 40%,
      rgba(0, 255, 255, 0.3) 50%,
      rgba(255, 255, 0, 0.3) 60%,
      rgba(255, 255, 255, 0) 80%,
      transparent 100%
    );
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .ai-product-card-wrapper-{{ ai_gen_id }}:hover .ai-product-card-shimmer-{{ ai_gen_id }} {
    opacity: {{ block.settings.shimmer_opacity }};
    animation: ai-shimmer-{{ ai_gen_id }} {{ block.settings.shimmer_speed }}s infinite;
  }

  .ai-product-card-wrapper-{{ ai_gen_id }}:hover .ai-product-card-image-{{ ai_gen_id }} {
    transform: scale(1.04);
  }

  @keyframes ai-shimmer-{{ ai_gen_id }} {
    0% {
      left: -100%;
    }
    100% {
      left: 100%;
    }
  }

  .ai-product-card-content-{{ ai_gen_id }} {
    padding: {{ block.settings.content_padding }}px;
    text-align: {{ block.settings.text_alignment }};
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .ai-product-card-title-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 8px 0;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    height: 2.8em;
  }

  .ai-product-card-price-{{ ai_gen_id }} {
    margin: 0 0 12px 0;
    display: flex;
    align-items: center;
    gap: 8px;
    justify-content: {% if block.settings.text_alignment == 'center' %}center{% elsif block.settings.text_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
    flex-wrap: wrap;
  }

  .ai-product-card-regular-price-{{ ai_gen_id }} {
    font-size: 15px;
    font-weight: 600;
    color: #222;
  }

  .ai-product-card-sale-price-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 700;
    color: #E30613;
  }

  .ai-product-card-compare-price-{{ ai_gen_id }} {
    font-size: 12px;
    color: #aaa;
    text-decoration: line-through;
    font-weight: 400;
  }

  .ai-product-card-savings-badge-{{ ai_gen_id }} {
    background-color: #fff0f0;
    color: #E30613;
    border-radius: 12px;
    padding: 2px 8px;
    font-size: 11px;
    font-weight: 600;
    display: inline-block;
  }

  .ai-product-card-button-wrap-{{ ai_gen_id }} {
    margin-top: auto;
    width: 100%;
  }

  .ai-product-card-btn-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 10px;
    border: 1.5px solid #E30613;
    color: #E30613;
    background-color: #ffffff;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.3px;
    border-radius: 8px;
    transition: all 0.3s ease;
    text-align: center;
  }

  .ai-product-card-wrapper-{{ ai_gen_id }}:hover .ai-product-card-btn-{{ ai_gen_id }} {
    background-color: #E30613;
    color: #ffffff;
  }

  .ai-product-card-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: inherit;
    display: block;
    height: 100%;
  }

  .ai-carousel-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    background-color: #E30613;
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 5;
    transition: all 0.2s ease;
    box-shadow: 0 4px 12px rgba(227,6,19,0.3);
  }

  .ai-carousel-nav-{{ ai_gen_id }}:hover {
    background-color: #c0000f;
    transform: translateY(-50%) scale(1.1);
  }

  .ai-carousel-nav-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-carousel-nav-prev-{{ ai_gen_id }} {
    left: 10px;
  }

  .ai-carousel-nav-next-{{ ai_gen_id }} {
    right: 10px;
  }

  .ai-carousel-nav-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    stroke: #ffffff;
  }

  .ai-product-card-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  /* Style custom heading wrapper for Top Picks */
  [class*="ai-text-title-heading-"] {
    position: relative !important;
    font-family: var(--font-heading) !important;
    font-weight: 700 !important;
    color: #111 !important;
    font-size: 30px !important;
    display: inline-block !important;
    padding-bottom: 14px !important;

    text-align: center !important;
  }

  [class*="ai-text-title-heading-"]::before {
    content: '' !important;
    position: absolute !important;
    bottom: 0 !important;
    left: 50% !important;
    transform: translateX(-50%) !important;
    width: 60px !important;
    height: 3px !important;
    background-color: #E30613 !important;
    border-radius: 2px !important;
  }

  [class*="ai-text-title-heading-"]::after {
    content: 'Our most loved products, just for you' !important;
    display: block !important;
    color: #888 !important;
    font-size: 14px !important;
    font-weight: 400 !important;
    font-family: var(--font-body), sans-serif !important;
    margin-top: 10px !important;
    line-height: 1.4 !important;
    text-transform: none !important;
  }

  @media screen and (max-width: 749px) {
    .ai-product-carousel-{{ ai_gen_id }} {
      width: 100%;
      padding: 40px 0;
    }

    .ai-product-carousel-container-{{ ai_gen_id }} {
      padding: 0 20px;
    }

    .ai-product-carousel-track-{{ ai_gen_id }} {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      gap: 16px;
      padding: 10px 0 20px;
    }

    .ai-product-carousel-slide-{{ ai_gen_id }} {
      flex: 0 0 85vw;
      scroll-snap-align: start;
    }

    .ai-product-card-image-container-{{ ai_gen_id }} {
      min-height: 240px;
      padding: 12px;
    }

    .ai-carousel-nav-{{ ai_gen_id }} {
      display: none !important;
    }
  }
{% endstyle %}

<product-carousel-{{ ai_gen_id }} class="ai-product-carousel-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-carousel-container-{{ ai_gen_id }}">
    <button class="ai-carousel-nav-{{ ai_gen_id }} ai-carousel-nav-prev-{{ ai_gen_id }}" aria-label="Previous slide">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
    </button>

    <div class="ai-product-carousel-track-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign product_key = 'product_' | append: i
          assign product = block.settings[product_key]
        %}

        {% if product != blank %}
          <div class="ai-product-carousel-slide-{{ ai_gen_id }}">
            <a href="{{ product.url }}" class="ai-product-card-link-{{ ai_gen_id }}">
              <div class="ai-product-card-wrapper-{{ ai_gen_id }}">
                <div class="ai-product-card-image-container-{{ ai_gen_id }}">
                  {% if product.featured_image %}
                    <img
                      src="{{ product.featured_image | image_url: width: 600 }}"
                      alt="{{ product.featured_image.alt | escape }}"
                      loading="lazy"
                      width="{{ product.featured_image.width }}"
                      height="{{ product.featured_image.height }}"
                      class="ai-product-card-image-{{ ai_gen_id }}"
                    >
                  {% else %}
                    <div class="ai-product-card-placeholder-{{ ai_gen_id }}">
                      {{ 'product-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                  {% if product.compare_at_price > product.price %}
                    <span class="ai-product-card-badge-{{ ai_gen_id }}">SALE</span>
                  {% endif %}
                  <div class="ai-product-card-shimmer-{{ ai_gen_id }}"></div>
                </div>

                <div class="ai-product-card-content-{{ ai_gen_id }}">
                  <h3 class="ai-product-card-title-{{ ai_gen_id }}">{{ product.title }}</h3>
                  <div class="ai-product-card-price-{{ ai_gen_id }}">
                    {% if product.compare_at_price > product.price %}
                      <span class="ai-product-card-compare-price-{{ ai_gen_id }}">
                        {{ product.compare_at_price | money | remove: ".00" }}
                      </span>
                      <span class="ai-product-card-sale-price-{{ ai_gen_id }}">
                        {{ product.price | money | remove: ".00" }}
                      </span>
                    {% else %}
                      <span class="ai-product-card-regular-price-{{ ai_gen_id }}">
                        {{ product.price | money | remove: ".00" }}
                      </span>
                    {% endif %}
                  </div>
                  <div class="ai-product-card-button-wrap-{{ ai_gen_id }}">
                    <span class="ai-product-card-btn-{{ ai_gen_id }}">View Product</span>
                  </div>
                </div>
              </div>
            </a>
          </div>
        {% else %}
          <div class="ai-product-carousel-slide-{{ ai_gen_id }}">
            <div class="ai-product-card-wrapper-{{ ai_gen_id }}">
              <div class="ai-product-card-image-container-{{ ai_gen_id }}">
                <div class="ai-product-card-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                  <div class="ai-product-card-empty-state-{{ ai_gen_id }}">
                    Add product {{ i }}
                  </div>
                </div>
                <div class="ai-product-card-shimmer-{{ ai_gen_id }}"></div>
              </div>

              <div class="ai-product-card-content-{{ ai_gen_id }}">
                <h3 class="ai-product-card-title-{{ ai_gen_id }}">Product {{ i }}</h3>
                <div class="ai-product-card-price-{{ ai_gen_id }}">
                  <span class="ai-product-card-regular-price-{{ ai_gen_id }}">₹0.00</span>
                </div>
                <div class="ai-product-card-button-wrap-{{ ai_gen_id }}">
                  <span class="ai-product-card-btn-{{ ai_gen_id }}">View Product</span>
                </div>
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <button class="ai-carousel-nav-{{ ai_gen_id }} ai-carousel-nav-next-{{ ai_gen_id }}" aria-label="Next slide">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </button>
  </div>
</product-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.track = null;
        this.prevButton = null;
        this.nextButton = null;
        this.slideWidth = 0;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-product-carousel-track-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-carousel-nav-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-carousel-nav-next-{{ ai_gen_id }}');

        if (!this.track || !this.prevButton || !this.nextButton) return;

        this.prevButton.addEventListener('click', () => this.scrollPrev());
        this.nextButton.addEventListener('click', () => this.scrollNext());
        this.track.addEventListener('scroll', () => this.updateButtons());

        this.updateSlideWidth();
        this.updateButtons();

        window.addEventListener('resize', () => {
          this.updateSlideWidth();
          this.updateButtons();
        });
      }

      updateSlideWidth() {
        const slide = this.track.querySelector('.ai-product-carousel-slide-{{ ai_gen_id }}');
        if (slide) {
          this.slideWidth = slide.offsetWidth + {{ block.settings.slide_gap }};
        }
      }

      scrollPrev() {
        this.track.scrollBy({
          left: -this.slideWidth,
          behavior: 'smooth'
        });
      }

      scrollNext() {
        this.track.scrollBy({
          left: this.slideWidth,
          behavior: 'smooth'
        });
      }

      updateButtons() {
        const scrollLeft = this.track.scrollLeft;
        const maxScroll = this.track.scrollWidth - this.track.clientWidth;

        this.prevButton.disabled = scrollLeft <= 0;
        this.nextButton.disabled = scrollLeft >= maxScroll - 1;
      }
    }

    customElements.define('product-carousel-{{ ai_gen_id }}', ProductCarousel{{ ai_gen_id }});
  })();
</script>

