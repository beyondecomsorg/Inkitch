{% doc %}
  @prompt
    Create a modern animated website section for Inkitch showcasing marketplaces where our products are available.
    
    Heading:
    “Available on Top Marketplaces”
    
    Subheading:
    “Shop Inkitch products across India’s leading platforms.”
    
    Requirements:
    
    * Horizontal auto-scrolling marketplace logos
    * Smooth infinite marquee animation
    * Glassmorphism or modern rounded cards
    * Hover effect with glow and slight scale
    * Pause animation on hover
    * Responsive for mobile and desktop
    
    Marketplaces:
    Amazon, Flipkart, Meesho, Myntra, Ajio, Snapdeal, JioMart, Shopify
    
    Style:
    Minimal, premium, modern eCommerce aesthetic similar to Stripe or Apple websites.
    
    Tech:
    React + Tailwind CSS + Framer Motion
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-marketplace-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    background: {{ block.settings.background_color }};
    overflow: hidden;
  }

  .ai-marketplace-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    text-align: center;
  }

  .ai-marketplace-header-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-marketplace-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 700;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px 0;
    line-height: 1.2;
  }

  .ai-marketplace-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
    opacity: 0.8;
    line-height: 1.5;
  }

  .ai-marketplace-marquee-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    );
  }

  .ai-marketplace-marquee-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    animation: ai-marketplace-scroll-{{ ai_gen_id }} {{ block.settings.animation_speed }}s linear infinite;
    will-change: transform;
  }

  .ai-marketplace-marquee-{{ ai_gen_id }}:hover {
    animation-play-state: paused;
  }

  .ai-marketplace-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    flex-shrink: 0;
  }

  .ai-marketplace-card-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.card_width }}px;
    height: {{ block.settings.card_height }}px;
    background: {{ block.settings.card_background }};
    backdrop-filter: blur({{ block.settings.blur_amount }}px);
    border: 1px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  }

  .ai-marketplace-card-{{ ai_gen_id }}:hover {
    transform: translateY(-8px) scale(1.05);
    box-shadow: 0 20px 25px -5px {{ block.settings.glow_color }}40,
                0 10px 10px -5px {{ block.settings.glow_color }}30;
    border-color: {{ block.settings.glow_color }};
  }

  .ai-marketplace-logo-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: grayscale({{ block.settings.logo_grayscale }}%);
    opacity: {{ block.settings.logo_opacity }};
    transition: all 0.3s ease;
  }

  .ai-marketplace-card-{{ ai_gen_id }}:hover .ai-marketplace-logo-{{ ai_gen_id }} {
    filter: grayscale(0%);
    opacity: 1;
  }

  .ai-marketplace-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: {{ block.settings.placeholder_bg }};
    border-radius: 8px;
    color: {{ block.settings.placeholder_text_color }};
    font-size: 14px;
    font-weight: 600;
    text-align: center;
    padding: 10px;
  }

  @keyframes ai-marketplace-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(calc(-100% - {{ block.settings.card_gap }}px));
    }
  }

  @media screen and (max-width: 749px) {
    .ai-marketplace-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-marketplace-subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.85);
    }

    .ai-marketplace-card-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_card_width }}px;
      height: {{ block.settings.mobile_card_height }}px;
    }

    .ai-marketplace-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.6 }}px 16px {{ block.settings.section_padding_bottom | times: 0.6 }}px;
    }
  }
{% endstyle %}

<marketplace-showcase-{{ ai_gen_id }} class="ai-marketplace-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-marketplace-container-{{ ai_gen_id }}">
    <div class="ai-marketplace-header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-marketplace-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subheading != blank %}
        <p class="ai-marketplace-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="ai-marketplace-marquee-wrapper-{{ ai_gen_id }}">
      <div class="ai-marketplace-marquee-{{ ai_gen_id }}">
        <div class="ai-marketplace-track-{{ ai_gen_id }}">
          {% for i in (1..8) %}
            {% liquid
              assign logo_key = 'marketplace_logo_' | append: i
              assign name_key = 'marketplace_name_' | append: i
              assign logo = block.settings[logo_key]
              assign name = block.settings[name_key]
            %}
            <div class="ai-marketplace-card-{{ ai_gen_id }}">
              {% if logo != blank %}
                <img
                  src="{{ logo | image_url: width: 400 }}"
                  alt="{{ name | escape }}"
                  class="ai-marketplace-logo-{{ ai_gen_id }}"
                  loading="lazy"
                  width="200"
                  height="100"
                >
              {% else %}
                <div class="ai-marketplace-placeholder-{{ ai_gen_id }}">
                  {% if name != blank %}
                    {{ name }}
                  {% else %}
                    Logo {{ i }}
                  {% endif %}
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </div>

        <div class="ai-marketplace-track-{{ ai_gen_id }}" aria-hidden="true">
          {% for i in (1..8) %}
            {% liquid
              assign logo_key = 'marketplace_logo_' | append: i
              assign name_key = 'marketplace_name_' | append: i
              assign logo = block.settings[logo_key]
              assign name = block.settings[name_key]
            %}
            <div class="ai-marketplace-card-{{ ai_gen_id }}">
              {% if logo != blank %}
                <img
                  src="{{ logo | image_url: width: 400 }}"
                  alt="{{ name | escape }}"
                  class="ai-marketplace-logo-{{ ai_gen_id }}"
                  loading="lazy"
                  width="200"
                  height="100"
                >
              {% else %}
                <div class="ai-marketplace-placeholder-{{ ai_gen_id }}">
                  {% if name != blank %}
                    {{ name }}
                  {% else %}
                    Logo {{ i }}
                  {% endif %}
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</marketplace-showcase-{{ ai_gen_id }}>

<script>
  (function() {
    class MarketplaceShowcase{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const marquee = this.querySelector('.ai-marketplace-marquee-{{ ai_gen_id }}');
        if (marquee) {
          marquee.setAttribute('role', 'region');
          marquee.setAttribute('aria-label', 'Marketplace logos carousel');
        }
      }
    }

    customElements.define('marketplace-showcase-{{ ai_gen_id }}', MarketplaceShowcase{{ ai_gen_id }});
  })();
</script>

