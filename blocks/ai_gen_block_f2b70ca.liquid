{% doc %}
  @prompt
    <div style="padding:40px 0;">
      <h2 style="text-align:center;font-size:42px;margin-bottom:30px;">
        Product Features
      </h2>
    
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:20px;">
    
        <div>
          <video autoplay loop muted playsinline width="100%">
            <source src="YOUR_VIDEO_LINK.mp4" type="video/mp4">
          </video>
          <h3>Dishwasher Safe</h3>
          <p>Top-rack dishwasher safe.</p>
        </div>
    
        <div>
          <video autoplay loop muted playsinline width="100%">
            <source src="YOUR_VIDEO_LINK.mp4" type="video/mp4">
          </video>
          <h3>Smooth Open & Close</h3>
          <p>Opens smoothly with ease.</p>
        </div>
    
        <div>
          <video autoplay loop muted playsinline width="100%">
            <source src="YOUR_VIDEO_LINK.mp4" type="video/mp4">
          </video>
          <h3>Invisible Hinge</h3>
          <p>Seamless hinge design.</p>
        </div>
    
        <div>
          <video autoplay loop muted playsinline width="100%">
            <source src="YOUR_VIDEO_LINK.mp4" type="video/mp4">
          </video>
          <h3>100% Leak Resistant</h3>
          <p>Tested against leakage.</p>
        </div>
    
      </div>
    </div>
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-features-{{ ai_gen_id }} {
    display: block;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    width: 100%;
  }

  .ai-product-features__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-product-features__heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
  }

  .ai-product-features__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-product-features__item-{{ ai_gen_id }} {
    text-align: {{ block.settings.item_alignment }};
  }

  .ai-product-features__media-{{ ai_gen_id }} {
    width: 100%;
    margin-bottom: {{ block.settings.media_spacing }}px;
    border-radius: {{ block.settings.media_border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.media_background }};
  }

  .ai-product-features__video-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-product-features__placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-features__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-product-features__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    color: {{ block.settings.title_color }};
  }

  .ai-product-features__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    margin: 0;
    color: {{ block.settings.description_color }};
    line-height: 1.5;
  }

  @media screen and (max-width: 989px) {
    .ai-product-features__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }

    .ai-product-features__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-product-features__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-product-features__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-product-features__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.9);
    }

    .ai-product-features__description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_size }}px * 0.9);
    }
  }
{% endstyle %}

<div class="ai-product-features-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-features__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-product-features__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    <div class="ai-product-features__grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign video_key = 'feature_' | append: i | append: '_video'
          assign title_key = 'feature_' | append: i | append: '_title'
          assign description_key = 'feature_' | append: i | append: '_description'
          
          assign video = block.settings[video_key]
          assign title = block.settings[title_key]
          assign description = block.settings[description_key]
        %}

        <div class="ai-product-features__item-{{ ai_gen_id }}">
          <div class="ai-product-features__media-{{ ai_gen_id }}">
            {% if video != blank %}
              <video
                class="ai-product-features__video-{{ ai_gen_id }}"
                autoplay
                loop
                muted
                playsinline
                {% if block.settings.lazy_load %}loading="lazy"{% endif %}
              >
                <source src="{{ video }}" type="video/mp4">
              </video>
            {% else %}
              <div class="ai-product-features__placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          {% if title != blank %}
            <h3 class="ai-product-features__title-{{ ai_gen_id }}">
              {{ title }}
            </h3>
          {% endif %}

          {% if description != blank %}
            <p class="ai-product-features__description-{{ ai_gen_id }}">
              {{ description }}
            </p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

