{% doc %}
  @prompt
    Here's the prompt to give Shopify AI:
    
    ---
    
    > Create a custom section called "Trust Badges" or "Store Features". It should have a light gray background color (hex #F5F5F5). The section displays 3 feature items in a single horizontal row, evenly spaced across the full width with generous padding on all sides.
    >
    > Each feature item has: a dark green outlined circular icon on the left (like a badge/seal icon, a box/returns icon, or a delivery truck icon — use SVG outline style icons, not filled), and to the right of the icon, a bold dark charcoal heading (like "Best price", "Easy Returns", "Fast shipping") with a smaller gray description paragraph below it. The icon and text should be vertically centered with each other.
    >
    > The background color of the section is light gray (#F5F5F5). The icon circles should have a dark green outline color (hex #1D5C3A) with the icon inside also in the same dark green. The heading text should be dark charcoal (hex #1A1A1A) and the description text should be medium gray (hex #555555).
    >
    > Each feature item's icon, heading text, and description text should all be editable from the theme editor. Allow up to 4 feature items and a minimum of 1. On mobile, the 3 items should stack vertically in a single column, each with the icon and text side by side.
    
    ---
    
    **Bonus tip** — add this for icon flexibility:
    
    > Allow me to choose the icon for each feature item from a set of common ecommerce icons (badge/seal, box, truck, lock, heart, star, clock, leaf) via a dropdown in the theme editor, so I don't need to upload custom images., Create a custom section called "Trust Badges". It should have a light gray background color (hex #F5F5F5) with top and bottom padding of 20px. Display 5 trust badge items in a single horizontal row, evenly spaced across the full width.
    Each badge item has a dark green outlined circular icon (hex #1D5C3A) on the left and text to the right. Use these exact 5 badges in this order:
    
    Shield/checkmark icon — heading "Secure Payment", description "100% secure & encrypted checkout"
    Refresh/return arrows icon — heading "Easy Returns", description "30-day hassle-free return policy"
    Delivery truck icon — heading "Fast Shipping", description "Free shipping on orders over $50"
    Ribbon/medal icon — heading "Best Price", description "Guaranteed unbeatable prices always"
    Headset/support icon — heading "24/7 Support", description "Dedicated support team always available"
    
    The icon circles should be outlined style (not filled) in dark green (#1D5C3A). Heading text in bold dark charcoal (#1A1A1A), description in medium gray (#555555). Each item's icon, heading, and description should be editable from the theme editor. On mobile, display 2 items per row and wrap to the next line, keeping icon and text side by side within each item.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-trust-badges-section-{{ ai_gen_id }} {
    display: block;
    background: linear-gradient(135deg, #c0000f 0%, #E30613 60%, #ff2020 100%) !important;
    position: relative;
    border-top: 2px solid rgba(255,255,255,0.3) !important;
    border-bottom: 2px solid rgba(255,255,255,0.3) !important;
    width: 100%;
    box-sizing: border-box;
  }

  .ai-trust-badges-section-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: repeating-linear-gradient(
      45deg, rgba(255,255,255,0.03) 0px,
      rgba(255,255,255,0.03) 1px, transparent 1px, transparent 10px
    );
    pointer-events: none;
    z-index: 1;
  }

  .ai-trust-badges-container-{{ ai_gen_id }} {
    max-width: 1200px !important;
    margin: 0 auto;
    padding: 28px 40px !important;
    position: relative;
    z-index: 2;
  }

  .ai-trust-badges-grid-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0;
  }

  @keyframes fadeUp-{{ ai_gen_id }} { 
    from { opacity: 0; transform: translateY(16px); } 
    to { opacity: 1; transform: translateY(0); } 
  }

  .ai-trust-badge-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex: 1;
    padding: 0 16px;
    box-sizing: border-box;
    border-right: 1px solid rgba(255,255,255,0.2);
    cursor: default;
    transition: transform 0.3s ease;
    
    /* Animation settings */
    opacity: 0;
    animation: fadeUp-{{ ai_gen_id }} 0.5s ease forwards;
  }

  .ai-trust-badge-item-{{ ai_gen_id }}:last-child {
    border-right: none;
  }

  .ai-trust-badge-item-{{ ai_gen_id }}:nth-child(1) { animation-delay: 0ms; }
  .ai-trust-badge-item-{{ ai_gen_id }}:nth-child(2) { animation-delay: 100ms; }
  .ai-trust-badge-item-{{ ai_gen_id }}:nth-child(3) { animation-delay: 200ms; }
  .ai-trust-badge-item-{{ ai_gen_id }}:nth-child(4) { animation-delay: 300ms; }
  .ai-trust-badge-item-{{ ai_gen_id }}:nth-child(5) { animation-delay: 400ms; }

  .ai-trust-badge-item-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-trust-badge-icon-{{ ai_gen_id }} {
    width: 52px !important;
    height: 52px !important;
    border-radius: 50% !important;
    background: rgba(255,255,255,0.15) !important;
    border: 1.5px solid rgba(255,255,255,0.3) !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    margin: 0 auto 12px auto !important;
    transition: all 0.3s ease !important;
    box-sizing: border-box;
    flex-shrink: 0;
  }

  .ai-trust-badge-icon-{{ ai_gen_id }} svg {
    width: 24px !important;
    height: 24px !important;
    stroke: #ffffff !important;
    fill: none !important;
    stroke-width: 2 !important;
    transition: all 0.3s ease !important;
  }

  .ai-trust-badge-item-{{ ai_gen_id }}:hover .ai-trust-badge-icon-{{ ai_gen_id }} {
    background: #ffffff !important;
    border-color: #ffffff !important;
  }

  .ai-trust-badge-item-{{ ai_gen_id }}:hover .ai-trust-badge-icon-{{ ai_gen_id }} svg {
    stroke: #E30613 !important;
  }

  .ai-trust-badge-content-{{ ai_gen_id }} {
    flex: 1;
    width: 100%;
  }

  .ai-trust-badge-heading-{{ ai_gen_id }} {
    font-size: 14px !important;
    font-weight: 700 !important;
    color: #ffffff !important;
    letter-spacing: 0.3px !important;
    margin: 0 0 4px 0 !important;
    text-transform: none !important;
    line-height: 1.2;
  }

  .ai-trust-badge-description-{{ ai_gen_id }} {
    font-size: 12px !important;
    color: rgba(255,255,255,0.8) !important;
    line-height: 1.5 !important;
    max-width: 120px !important;
    margin: 0 auto !important;
  }

  @media screen and (max-width: 768px) {
    .ai-trust-badges-grid-{{ ai_gen_id }} {
      display: grid !important;
      grid-template-columns: repeat(3, 1fr) !important;
      gap: 20px !important;
    }

    .ai-trust-badge-item-{{ ai_gen_id }} {
      border-right: none !important;
      padding: 0 !important;
    }
  }

  @media screen and (max-width: 480px) {
    .ai-trust-badges-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 16px !important;
    }

    .ai-trust-badges-container-{{ ai_gen_id }} {
      padding: 20px 16px !important;
    }

    .ai-trust-badge-icon-{{ ai_gen_id }} {
      width: 44px !important;
      height: 44px !important;
      margin-bottom: 10px !important;
    }

    .ai-trust-badge-icon-{{ ai_gen_id }} svg {
      width: 20px !important;
      height: 20px !important;
    }

    .ai-trust-badge-heading-{{ ai_gen_id }} {
      font-size: 13px !important;
    }

    .ai-trust-badge-description-{{ ai_gen_id }} {
      font-size: 11px !important;
      max-width: 100% !important;
    }
  }
{% endstyle %}

