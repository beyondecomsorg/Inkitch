<div class="category-circles-section">

  <div class="category-heading-wrapper">
    <h2 class="category-heading">
      {{ block.settings.heading }}
    </h2>
    <p class="category-subtitle">Explore our wide range of stainless steel products</p>
  </div>

  <div class="category-slider">

    {% if block.settings.image_1 != blank %}
      <a href="{{ block.settings.link_1.url }}" class="category-item">
        <img src="{{ block.settings.image_1 | img_url: '500x500' }}" alt="{{ block.settings.title_1 }}">
        <p>{{ block.settings.title_1 }}</p>
        <span class="category-arrow">→</span>
      </a>
    {% endif %}

    {% if block.settings.image_2 != blank %}
      <a href="{{ block.settings.link_2.url }}" class="category-item">
        <img src="{{ block.settings.image_2 | img_url: '500x500' }}" alt="{{ block.settings.title_2 }}">
        <p>{{ block.settings.title_2 }}</p>
        <span class="category-arrow">→</span>
      </a>
    {% endif %}

    {% if block.settings.image_3 != blank %}
      <a href="{{ block.settings.link_3.url }}" class="category-item">
        <img src="{{ block.settings.image_3 | img_url: '500x500' }}" alt="{{ block.settings.title_3 }}">
        <p>{{ block.settings.title_3 }}</p>
        <span class="category-arrow">→</span>
      </a>
    {% endif %}

    {% if block.settings.image_4 != blank %}
      <a href="{{ block.settings.link_4.url }}" class="category-item">
        <img src="{{ block.settings.image_4 | img_url: '500x500' }}" alt="{{ block.settings.title_4 }}">
        <p>{{ block.settings.title_4 }}</p>
        <span class="category-arrow">→</span>
      </a>
    {% endif %}

    {% if block.settings.image_5 != blank %}
      <a href="{{ block.settings.link_5.url }}" class="category-item">
        <img src="{{ block.settings.image_5 | img_url: '500x500' }}" alt="{{ block.settings.title_5 }}">
        <p>{{ block.settings.title_5 }}</p>
        <span class="category-arrow">→</span>
      </a>
    {% endif %}

    {% if block.settings.image_6 != blank %}
      <a href="{{ block.settings.link_6.url }}" class="category-item">
        <img src="{{ block.settings.image_6 | img_url: '500x500' }}" alt="{{ block.settings.title_6 }}">
        <p>{{ block.settings.title_6 }}</p>
        <span class="category-arrow">→</span>
      </a>
    {% endif %}

    {% if block.settings.image_7 != blank %}
      <a href="{{ block.settings.link_7.url }}" class="category-item">
        <img src="{{ block.settings.image_7 | img_url: '500x500' }}" alt="{{ block.settings.title_7 }}">
        <p>{{ block.settings.title_7 }}</p>
        <span class="category-arrow">→</span>
      </a>
    {% endif %}

    {% if block.settings.image_8 != blank %}
      <a href="{{ block.settings.link_8.url }}" class="category-item">
        <img src="{{ block.settings.image_8 | img_url: '500x500' }}" alt="{{ block.settings.title_8 }}">
        <p>{{ block.settings.title_8 }}</p>
        <span class="category-arrow">→</span>
      </a>
    {% endif %}

  </div>

</div>

<style>

.category-circles-section {
  background-color: #f7f7f7;
  padding-top: 60px;
  padding-bottom: 60px;
  position: relative;
  border-top: 4px solid #E30613;
}

.category-heading-wrapper {
  text-align: center;
  margin-bottom: 40px;
}

.category-heading {
  font-size: clamp(28px, 4vw, 36px);
  font-weight: 700;
  color: #111;
  margin: 0 0 12px 0;
  position: relative;
  display: inline-block;
  font-family: var(--font-heading), serif;
}

.category-heading::after {
  content: '';
  display: block;
  width: 60px;
  height: 3px;
  background-color: #E30613;
  margin: 8px auto 0;
  border-radius: 2px;
}

.category-subtitle {
  font-size: 14px;
  color: #888;
  margin: 0;
  font-family: var(--font-body), sans-serif;
}

.category-slider {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: stretch;
  flex-wrap: wrap;
  gap: 24px;
  padding: 10px 0;
}

.category-item {
  width: 160px;
  background-color: #ffffff;
  border-radius: 16px;
  box-shadow: 0 4px 16px rgba(0,0,0,0.08);
  padding: 20px 12px;
  text-align: center;
  text-decoration: none;
  color: inherit;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s ease;
  flex-shrink: 0;
  border: 1px solid rgba(0,0,0,0.02);
}

.category-item:hover {
  transform: translateY(-8px);
  box-shadow: 0 12px 24px rgba(0,0,0,0.14);
}

.category-item img {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  object-fit: cover;
  display: block;
  margin: 0 auto;
  border: none;
  box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  outline: 3px solid transparent;
  outline-offset: 4px;
  transition: outline 0.3s ease, transform 0.3s ease;
}

.category-item:hover img {
  outline: 3px solid #E30613;
}

.category-item p {
  font-weight: 600;
  color: #222;
  font-size: 14px;
  margin: 12px 0 4px 0;
  line-height: 1.3;
  transition: color 0.3s ease;
}

.category-item:hover p {
  color: #E30613;
}

.category-arrow {
  color: #E30613;
  font-size: 16px;
  font-weight: 700;
  opacity: 0;
  transform: translateX(-10px);
  transition: all 0.3s ease;
  margin-top: 4px;
}

.category-item:hover .category-arrow {
  opacity: 1;
  transform: translateX(0);
}

@media screen and (max-width: 768px) {
  .category-circles-section {
    padding: 40px 15px;
  }

  .category-heading-wrapper {
    margin-bottom: 24px;
  }

  .category-slider {
    flex-wrap: nowrap;
    justify-content: flex-start;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 15px;
    gap: 16px;
  }

  .category-slider::-webkit-scrollbar {
    display: none;
  }

  .category-item {
    scroll-snap-align: start;
    min-width: 140px;
    width: 140px;
    padding: 16px 8px;
  }

  .category-item img {
    width: 90px;
    height: 90px;
  }

  .category-item p {
    font-size: 13px;
    margin-top: 10px;
  }
}

</style>

