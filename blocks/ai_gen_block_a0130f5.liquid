{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-accordion-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.item_spacing }}px;
  }

  .ai-accordion-item-{{ ai_gen_id }} {
    background: {{ block.settings.item_background_color }};
    border-radius: {{ block.settings.item_border_radius }}px;
    overflow: hidden;
    transition: box-shadow 0.2s ease;
  }

  .ai-accordion-item-{{ ai_gen_id }}:hover {
    box-shadow: 0 2px 12px rgba(0, 0, 0, {{ block.settings.hover_shadow_opacity }});
  }

  .ai-accordion-header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: {{ block.settings.header_padding_vertical }}px {{ block.settings.header_padding_horizontal }}px;
    cursor: pointer;
    user-select: none;
    -webkit-user-select: none;
  }

  .ai-accordion-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    color: {{ block.settings.title_color }};
    letter-spacing: -0.1px;
  }

  .ai-accordion-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    min-width: {{ block.settings.icon_size }}px;
    background: {{ block.settings.icon_background_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), background 0.2s ease;
  }

  .ai-accordion-icon-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.icon_size }}px * 0.44);
    height: calc({{ block.settings.icon_size }}px * 0.44);
    stroke: {{ block.settings.icon_color }};
    stroke-width: 2.5;
    stroke-linecap: round;
    fill: none;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ai-accordion-item-{{ ai_gen_id }}.open .ai-accordion-icon-{{ ai_gen_id }} {
    transform: rotate(45deg);
  }

  .ai-accordion-body-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ai-accordion-content-{{ ai_gen_id }} {
    padding: 0 {{ block.settings.header_padding_horizontal }}px {{ block.settings.content_padding_bottom }}px;
    font-size: {{ block.settings.content_font_size }}px;
    color: {{ block.settings.content_color }};
    line-height: 1.7;
  }

  .ai-accordion-content-{{ ai_gen_id }} ul {
    padding-left: 18px;
    margin-top: 6px;
  }

  .ai-accordion-content-{{ ai_gen_id }} ul li {
    margin-bottom: 6px;
  }

  .ai-accordion-content-{{ ai_gen_id }} p {
    margin-bottom: 8px;
  }

  .ai-accordion-divider-{{ ai_gen_id }} {
    height: 1px;
    background: {{ block.settings.divider_color }};
    margin: 0 {{ block.settings.header_padding_horizontal }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-accordion-wrapper-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-accordion-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_font_size }}px * 0.9);
    }

    .ai-accordion-content-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.content_font_size }}px * 0.95);
    }
  }
{% endstyle %}

<product-accordion-{{ ai_gen_id }} class="ai-accordion-wrapper-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% for i in (1..4) %}
    {% liquid
      assign title_key = 'item_' | append: i | append: '_title'
      assign content_key = 'item_' | append: i | append: '_content'
      assign enabled_key = 'item_' | append: i | append: '_enabled'
      
      assign item_title = block.settings[title_key]
      assign item_content = block.settings[content_key]
      assign item_enabled = block.settings[enabled_key]
    %}

    {% if item_enabled %}
      <div class="ai-accordion-item-{{ ai_gen_id }}" data-accordion-item>
        <div class="ai-accordion-header-{{ ai_gen_id }}" role="button" aria-expanded="false" tabindex="0">
          <span class="ai-accordion-title-{{ ai_gen_id }}">{{ item_title }}</span>
          <div class="ai-accordion-icon-{{ ai_gen_id }}">
            <svg viewBox="0 0 14 14">
              <line x1="7" y1="1" x2="7" y2="13"/>
              <line x1="1" y1="7" x2="13" y2="7"/>
            </svg>
          </div>
        </div>
        <div class="ai-accordion-body-{{ ai_gen_id }}">
          <div class="ai-accordion-divider-{{ ai_gen_id }}"></div>
          <div class="ai-accordion-content-{{ ai_gen_id }}">
            {{ item_content }}
          </div>
        </div>
      </div>
    {% endif %}
  {% endfor %}
</product-accordion-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductAccordion{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.items = [];
      }

      connectedCallback() {
        this.items = this.querySelectorAll('[data-accordion-item]');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.items.forEach((item) => {
          const header = item.querySelector('.ai-accordion-header-{{ ai_gen_id }}');
          const body = item.querySelector('.ai-accordion-body-{{ ai_gen_id }}');

          header.addEventListener('click', () => this.toggleItem(item, header, body));
          header.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              this.toggleItem(item, header, body);
            }
          });
        });
      }

      toggleItem(item, header, body) {
        const isOpen = item.classList.contains('open');

        if (isOpen) {
          this.closeItem(item, header, body);
        } else {
          this.openItem(item, header, body);
        }
      }

      openItem(item, header, body) {
        item.classList.add('open');
        header.setAttribute('aria-expanded', 'true');
        body.style.maxHeight = body.scrollHeight + 'px';
      }

      closeItem(item, header, body) {
        item.classList.remove('open');
        header.setAttribute('aria-expanded', 'false');
        body.style.maxHeight = '0';
      }
    }

    customElements.define('product-accordion-{{ ai_gen_id }}', ProductAccordion{{ ai_gen_id }});
  })();
</script>

