{% doc %}
  @prompt
    Create a custom Shopify liquid section called "Trust Badges". It has a clean white background with generous top and bottom padding (40px). Display 4 trust badge items in a single horizontal row, evenly spaced and centered across the full width.
    Each badge item is stacked vertically — a large circular icon on top and a short label text centered below it. The icon is a thin outline style circle (around 80px diameter) with a red border (hex #E8001D) and a matching red outline icon inside the circle. The label text below each icon is in small dark charcoal text (hex #1A1A1A), centered, font size around 14px, with a small gap between the circle and the text.
    Use these exact 4 badges in this order:
    
    A medal/ribbon award icon inside the circle — label: "1+1 Year Warranty"
    A box with circular refresh/return arrows around it — label: "7 Day Return"
    A shield with a checkmark inside — label: "Quality Verified"
    A delivery truck with speed lines — label: "Free Shipping"
    
    All icons must be SVG outline style, thin stroke weight (around 1.5px), red color (hex #E8001D). The circle border around each icon should also be red (hex #E8001D), thin outline, not filled. No background color inside the circles — keep it white inside.
    All 4 badge label texts should be editable from the Shopify theme editor. Allow me to toggle each badge on or off individually. The icon style and circle color should have a color picker setting in the theme editor so I can change the red to any brand color easily. On mobile display 2 badges per row in a 2x2 grid layout, keeping the same icon and label style., i want more red bold colour 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-trust-badges-{{ ai_gen_id }} {
    display: block;
    background-color: #ffffff;
    padding: 40px 20px;
    width: 100%;
  }

  .ai-trust-badges-container-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 40px;
    max-width: 1200px;
    margin: 0 auto;
    flex-wrap: wrap;
  }

  .ai-trust-badge-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    flex: 1 1 auto;
    min-width: 150px;
    max-width: 250px;
  }

  .ai-trust-badge-icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    border: {{ block.settings.border_width }}px solid {{ block.settings.icon_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: transparent;
  }

  .ai-trust-badge-icon-wrapper-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.icon_size }}px * 0.5);
    height: calc({{ block.settings.icon_size }}px * 0.5);
    stroke: {{ block.settings.icon_color }};
    fill: none;
    stroke-width: {{ block.settings.stroke_width }};
  }

  .ai-trust-badge-label-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    text-align: center;
    line-height: 1.4;
    margin: 0;
    font-weight: {{ block.settings.text_weight }};
  }

  @media screen and (max-width: 749px) {
    .ai-trust-badges-container-{{ ai_gen_id }} {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 30px 20px;
    }

    .ai-trust-badge-item-{{ ai_gen_id }} {
      max-width: 100%;
    }
  }
{% endstyle %}

<trust-badges-{{ ai_gen_id }} class="ai-trust-badges-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-trust-badges-container-{{ ai_gen_id }}">
    {% if block.settings.badge_1_enabled %}
      <div class="ai-trust-badge-item-{{ ai_gen_id }}">
        <div class="ai-trust-badge-icon-wrapper-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="8" r="4"></circle>
            <path d="M12 12L8 22l4-2 4 2-4-10z"></path>
            <path d="M8 12l-2 10"></path>
            <path d="M16 12l2 10"></path>
          </svg>
        </div>
        <p class="ai-trust-badge-label-{{ ai_gen_id }}">{{ block.settings.badge_1_text }}</p>
      </div>
    {% endif %}

    {% if block.settings.badge_2_enabled %}
      <div class="ai-trust-badge-item-{{ ai_gen_id }}">
        <div class="ai-trust-badge-icon-wrapper-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2"></rect>
            <path d="M16 2v4"></path>
            <path d="M8 2v4"></path>
            <path d="M3 10h18"></path>
            <path d="M8 14l3 3 5-5"></path>
          </svg>
        </div>
        <p class="ai-trust-badge-label-{{ ai_gen_id }}">{{ block.settings.badge_2_text }}</p>
      </div>
    {% endif %}

    {% if block.settings.badge_3_enabled %}
      <div class="ai-trust-badge-item-{{ ai_gen_id }}">
        <div class="ai-trust-badge-icon-wrapper-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            <path d="M9 12l2 2 4-4"></path>
          </svg>
        </div>
        <p class="ai-trust-badge-label-{{ ai_gen_id }}">{{ block.settings.badge_3_text }}</p>
      </div>
    {% endif %}

    {% if block.settings.badge_4_enabled %}
      <div class="ai-trust-badge-item-{{ ai_gen_id }}">
        <div class="ai-trust-badge-icon-wrapper-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="6" width="18" height="12" rx="2"></rect>
            <path d="M19 9l4-3v12l-4-3"></path>
            <path d="M1 12h4"></path>
            <path d="M5 9l-2-2"></path>
            <path d="M5 15l-2 2"></path>
          </svg>
        </div>
        <p class="ai-trust-badge-label-{{ ai_gen_id }}">{{ block.settings.badge_4_text }}</p>
      </div>
    {% endif %}
  </div>
</trust-badges-{{ ai_gen_id }}>

<script>
  (function() {
    class TrustBadges{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('trust-badges-{{ ai_gen_id }}', TrustBadges{{ ai_gen_id }});
  })();
</script>

