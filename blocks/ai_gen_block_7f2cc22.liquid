      "default": "BACK IN STOCK"
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label color",
      "default": "#f5f5dc"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sleek & Functional Tea Kettle"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "color",
      "id": "heading_color",
