{% doc %}
  @prompt
    Create a custom section called "Promotional Banner". It should be a full-width wide banner with a solid dark green background color. The banner is split into two halves side by side.
    The left half contains text content aligned to the left with padding. At the top, show a small uppercase tracking-spaced label (like "BACK IN STOCK") in a light cream/off-white color. Below that, display a large bold white heading (like "Sleek & Functional Tea Kettle") in a heavy font. Under the heading, show a short paragraph description in a slightly smaller light cream color. Below the description, add a rectangular button with a white background, dark text, no border radius, and bold uppercase text (like "SHOP NOW") that links to a product or collection page.
    The right half displays two images arranged in a collage layout — one image positioned in the top-right corner that is slightly inset from the top (like a lifestyle photo), and one larger product image overlapping and extending below it, slightly overlapping the left text area. Both images should be uploadable from the theme editor.
    All text fields (label, heading, description, button text, button link) should be editable from the theme editor. The background color should also be a customizable color setting. On mobile, the banner should stack vertically — text on top, images below.
    The product image on the right should have a subtle drop shadow to make it appear lifted above the background. The lifestyle photo in the top-right corner should be displayed as a rectangular crop with no border radius., optimise this for moblie friendly also 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-promo-banner-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: linear-gradient(135deg, #c0000f 0%, #E30613 50%, #ff1a1a 100%);
    background-image: repeating-linear-gradient(
      45deg, rgba(255,255,255,0.03) 0px, 
      rgba(255,255,255,0.03) 1px, transparent 1px, transparent 12px
    ), linear-gradient(135deg, #c0000f 0%, #E30613 50%, #ff1a1a 100%);
    overflow: hidden;
    position: relative;
    clip-path: polygon(0 0, 100% 0, 100% 92%, 0 100%);
  }

  .ai-promo-banner-circle-decor-{{ ai_gen_id }} {
    position: absolute;
    bottom: -150px;
    left: -150px;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background-color: #ffffff;
    opacity: 0.04;
    pointer-events: none;
    z-index: 1;
  }

  .ai-promo-banner-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    max-width: 100%;
    min-height: 520px;
  }

  .ai-promo-banner-text-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: {{ block.settings.text_padding }}px;
    position: relative;
    z-index: 2;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .ai-promo-banner-label-{{ ai_gen_id }} {
    display: inline-block;
    background-color: rgba(255,255,255,0.15);
    color: #ffffff;
    border: 1px solid rgba(255,255,255,0.3);
    border-radius: 20px;
    padding: 4px 14px;
    font-size: 11px;
    letter-spacing: 1.5px;
    font-weight: 700;
    margin-bottom: 20px;
    align-self: flex-start;
    opacity: 0;
    animation: fadeUp 0.5s ease forwards;
    font-family: var(--font-body), sans-serif;
  }

  .ai-promo-banner-heading-{{ ai_gen_id }} {
    font-size: 48px;
    font-weight: 800;
    color: #ffffff;
    line-height: 1.15;
    margin: 0 0 20px 0;
    opacity: 0;
    animation: fadeUp 0.7s ease 0.1s forwards;
    font-family: var(--font-heading), serif;
  }

  .ai-promo-banner-description-{{ ai_gen_id }} {
    color: rgba(255,255,255,0.85);
    font-size: 15px;
    line-height: 1.7;
    max-width: 420px;
    margin-bottom: 30px;
    opacity: 0;
    animation: fadeUp 0.7s ease 0.2s forwards;
    font-family: var(--font-body), sans-serif;
  }

  .ai-promo-banner-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background-color: #ffffff;
    color: #E30613;
    font-weight: 700;
    font-size: 15px;
    letter-spacing: 0.5px;
    border-radius: 8px;
    padding: 14px 36px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    text-decoration: none;
    transition: all 0.3s ease;
    align-self: flex-start;
    opacity: 0;
    animation: fadeUp 0.7s ease 0.3s forwards;
  }

  .ai-promo-banner-button-{{ ai_gen_id }}:hover {
    background-color: #111111;
    color: #ffffff;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.3);
  }

  .ai-promo-banner-button-{{ ai_gen_id }} span {
    display: inline-block;
    transition: transform 0.3s ease;
  }

  .ai-promo-banner-button-{{ ai_gen_id }}:hover span {
    transform: translateX(4px);
  }

  @keyframes fadeInRight {
    from {
      opacity: 0;
      transform: translateX(40px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes pulse {
    from {
      transform: scale(0.95);
    }
    to {
      transform: scale(1.05);
    }
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-8px);
    }
  }

  .ai-promo-banner-images-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
    overflow: hidden;
  }

  .ai-promo-banner-glow-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 360px;
    height: 360px;
    margin-top: -180px;
    margin-left: -180px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, transparent 70%);
    animation: pulse 3s ease-in-out infinite alternate;
    z-index: 1;
    pointer-events: none;
  }

  .ai-promo-banner-lifestyle-wrapper-{{ ai_gen_id }} {
    position: absolute;
    top: 40px;
    right: 40px;
    width: 45%;
    z-index: 1;
    opacity: 0.8;
  }

  .ai-promo-banner-lifestyle-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-promo-banner-lifestyle-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: rgba(255, 255, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-promo-banner-lifestyle-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-promo-banner-product-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 60%;
    margin-top: 80px;
    z-index: 2;
  }

  .ai-promo-banner-product-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    filter: drop-shadow(0 20px 40px rgba(0,0,0,0.3));
    opacity: 0;
    animation: fadeInRight 0.9s ease 0.2s forwards;
    transition: transform 0.4s ease;
  }

  .ai-promo-banner-product-{{ ai_gen_id }}:hover {
    transform: scale(1.03) rotate(1deg);
  }

  .ai-promo-banner-product-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 3 / 4;
    background-color: rgba(255, 255, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    filter: drop-shadow(0 20px 40px rgba(0,0,0,0.3));
    opacity: 0;
    animation: fadeInRight 0.9s ease 0.2s forwards;
  }

  .ai-promo-banner-product-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.4;
  }

  .ai-promo-banner-badge-1-{{ ai_gen_id }},
  .ai-promo-banner-badge-2-{{ ai_gen_id }} {
    background-color: #ffffff;
    border-radius: 12px;
    padding: 10px 16px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.15);
    font-weight: 700;
    font-size: 13px;
    color: #111111;
    z-index: 3;
    white-space: nowrap;
  }

  .ai-promo-banner-badge-1-{{ ai_gen_id }} {
    position: absolute;
    top: 20px;
    right: 20px;
    animation: float 3s ease-in-out infinite;
  }

  .ai-promo-banner-badge-2-{{ ai_gen_id }} {
    position: absolute;
    bottom: 30px;
    left: 10px;
    animation: float 3s ease-in-out 1s infinite;
  }

  @media screen and (max-width: 768px) {
    .ai-promo-banner-{{ ai_gen_id }} {
      clip-path: none;
    }

    .ai-promo-banner-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .ai-promo-banner-text-{{ ai_gen_id }} {
      padding: 40px 20px;
      order: 2;
      text-align: center;
      align-items: center;
    }

    .ai-promo-banner-heading-{{ ai_gen_id }} {
      font-size: 26px;
      text-align: center;
    }

    .ai-promo-banner-description-{{ ai_gen_id }} {
      font-size: 14px;
      margin: 0 auto 20px;
      text-align: center;
    }

    .ai-promo-banner-button-{{ ai_gen_id }} {
      align-self: center;
      width: auto;
    }

    .ai-promo-banner-images-{{ ai_gen_id }} {
      order: 1;
      padding: 40px 20px;
      min-height: auto;
      height: 280px;
    }

    .ai-promo-banner-lifestyle-wrapper-{{ ai_gen_id }} {
      display: none;
    }

    .ai-promo-banner-product-wrapper-{{ ai_gen_id }} {
      width: auto;
      height: 100%;
      margin-top: 0;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .ai-promo-banner-product-{{ ai_gen_id }},
    .ai-promo-banner-product-placeholder-{{ ai_gen_id }} {
      max-height: 280px;
      width: auto;
      filter: drop-shadow(0 6px 20px rgba(0, 0, 0, 0.25));
    }

    .ai-promo-banner-badge-1-{{ ai_gen_id }},
    .ai-promo-banner-badge-2-{{ ai_gen_id }} {
      display: none !important;
    }
  }
{% endstyle %}

<promotional-banner-{{ ai_gen_id }} class="ai-promo-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-promo-banner-circle-decor-{{ ai_gen_id }}"></div>
  <div class="ai-promo-banner-container-{{ ai_gen_id }}">
    <div class="ai-promo-banner-text-{{ ai_gen_id }}">
      {% if block.settings.label != blank %}
        <div class="ai-promo-banner-label-{{ ai_gen_id }}">
          {{ block.settings.label }}
        </div>
      {% endif %}

      {% if block.settings.heading != blank %}
        <h2 class="ai-promo-banner-heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}

      {% if block.settings.description != blank %}
        <div class="ai-promo-banner-description-{{ ai_gen_id }}">
          {{ block.settings.description }}
        </div>
      {% endif %}

      {% if block.settings.button_text != blank %}
        <a href="{{ block.settings.button_link }}" class="ai-promo-banner-button-{{ ai_gen_id }}">
          {{ block.settings.button_text }} <span>&rarr;</span>
        </a>
      {% endif %}
    </div>

    <div class="ai-promo-banner-images-{{ ai_gen_id }}">
      <div class="ai-promo-banner-glow-{{ ai_gen_id }}"></div>

      <div class="ai-promo-banner-lifestyle-wrapper-{{ ai_gen_id }}">
        {% if block.settings.lifestyle_image %}
          <img
            src="{{ block.settings.lifestyle_image | image_url: width: 800 }}"
            alt="{{ block.settings.lifestyle_image.alt | escape }}"
            class="ai-promo-banner-lifestyle-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.lifestyle_image.width }}"
            height="{{ block.settings.lifestyle_image.height }}"
          >
        {% else %}
          <div class="ai-promo-banner-lifestyle-placeholder-{{ ai_gen_id }}">
            {{ 'lifestyle-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      <div class="ai-promo-banner-product-wrapper-{{ ai_gen_id }}">
        {% if block.settings.product_image %}
          <img
            src="{{ block.settings.product_image | image_url: width: 1000 }}"
            alt="{{ block.settings.product_image.alt | escape }}"
            class="ai-promo-banner-product-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.product_image.width }}"
            height="{{ block.settings.product_image.height }}"
          >
        {% else %}
          <div class="ai-promo-banner-product-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      <div class="ai-promo-banner-badge-1-{{ ai_gen_id }}">
        🔥 Best Seller
      </div>
      <div class="ai-promo-banner-badge-2-{{ ai_gen_id }}">
        ✅ ISI Certified
      </div>
    </div>
  </div>
</promotional-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class PromotionalBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('promotional-banner-{{ ai_gen_id }}', PromotionalBanner{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Promotional banner",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#1a4d2e"
    },
    {
      "type": "header",
      "content": "Text content"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "BACK IN STOCK"
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Label size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label color",
      "default": "#f5f5dc"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sleek & Functional Tea Kettle"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "textarea",
      "id": "description",
